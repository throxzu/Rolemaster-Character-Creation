@page "/character/{Id:int}/sheet"
@rendermode InteractiveServer
@attribute [Authorize]
<HeadContent>
    <link rel="stylesheet" href="character-sheet.css" />
</HeadContent>
@using RolemasterCharacterCreation.Data
@using RolemasterCharacterCreation.Models
@using RolemasterCharacterCreation.Rules
@using System.Security.Claims
@inject AppDbContext Db
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject NavigationManager Nav

<PageTitle>@(_char?.Name ?? "Character") — Sheet</PageTitle>

<div class="d-print-none mb-3 d-flex align-items-center flex-wrap gap-2">
    <button class="btn btn-primary" onclick="window.print()">Print</button>
    <a class="btn btn-outline-secondary" href="@(_isGm ? "/gm/characters" : "/characters")">← Back</a>
    @if (_isGm || _playerCanAccessWizard)
    {
        <a class="btn btn-outline-primary" href="/character/@Id/wizard">Wizard</a>
    }
    @if (_isGm && _char is not null)
    {
        <span class="d-inline-flex align-items-center gap-1 ms-2">
            <label class="form-label mb-0 small text-muted">EP:</label>
            <input type="number" class="form-control form-control-sm" style="width:110px" min="0"
                   value="@_char.CurrentXp"
                   @onchange="SaveXpAsync" />
            <span class="text-muted small">/ @(10000 * _char.Level) for Lv @(_char.Level + 1)</span>
        </span>
    }
    @if (_canLevelUp)
    {
        <button class="btn btn-outline-warning" @onclick="LevelUpAsync">
            Level Up (Lv @_char!.Level → @(_char.Level + 1))
        </button>
    }
</div>

@if (_char is null) { <p>Loading…</p> return; }
@if (_accessDenied) { <div class="alert alert-danger">Access denied.</div> return; }

<div class="qp-card">
<div class="rm">

<!-- ═══════════ PAGE 1 ═══════════ -->

<!-- HEADER -->
<table class="t100 tb mb1">
  <tr>
    <td colspan="4" class="hdr tc" style="width:65%">Character</td>
    <td class="hdr tc" style="width:12%">Level</td>
    <td class="hdr tc" style="width:23%">EP for next level</td>
  </tr>
  <tr>
    <td colspan="2" class="p1" style="width:30%"><div class="lbl">Character Name</div><div class="val fw">@_char.Name</div></td>
    <td class="p1"><div class="lbl">Player Name:</div><div class="val"></div></td>
    <td class="p1"><div class="lbl">Current EP</div><div class="val">@_char.CurrentXp</div></td>
    <td class="p1"><div class="lbl">Level</div><div class="val fw">@_char.Level</div></td>
    <td class="p1"><div class="lbl">EP for next level</div><div class="val">@(10000 * _char.Level)</div></td>
  </tr>
  <tr>
    <td colspan="4" class="p1"><div class="lbl">Campaign:</div><div class="val"></div></td>
    <td colspan="2" class="p1"></td>
  </tr>
</table>

<!-- APPEARANCE / BACKGROUND / FEATS OF STRENGTH / ENCUMBRANCE -->
<table class="t100 tb mb1">
  <tr>
    <td class="hdr" style="width:22%">Appearance</td>
    <td class="hdr" style="width:18%">Background</td>
    <td class="hdr" style="width:27%">Feats of Strength</td>
    <td class="hdr" style="width:33%">Encumbrance</td>
  </tr>
  <tr>
    <td class="p1 vt">
      <table class="t100">
        <tr><td class="fhalf p1"><span class="lbl">Sex:</span> @(_char.Gender ?? "")</td><td class="fhalf p1"><span class="lbl">Build:</span> @(_char.Build ?? "")</td></tr>
        <tr><td class="fhalf p1"><span class="lbl">Age:</span> @(_char.Age.HasValue ? _char.Age.Value.ToString() : "")</td><td class="fhalf p1"><span class="lbl">Skin:</span></td></tr>
        <tr><td class="fhalf p1"><span class="lbl">Height:</span> @(_char.HeightCm.HasValue ? FmtHeight(_char.HeightCm.Value) : "")</td><td class="fhalf p1"><span class="lbl">Hair:</span> @(_char.HairColor ?? "")</td></tr>
        <tr><td class="fhalf p1"><span class="lbl">Weight:</span> @(_char.WeightKg.HasValue ? FmtWeight(_char.WeightKg.Value) : "")</td><td class="fhalf p1"><span class="lbl">Eyes:</span> @(_char.EyeColor ?? "")</td></tr>
      </table>
    </td>
    <td class="p1 vt">
      <table class="t100">
        <tr><td class="p1 bb"><div class="lbl">Race:</div><div class="val">@(_char.Race ?? "")</div></td></tr>
        <tr><td class="p1 bb"><div class="lbl">Culture:</div><div class="val">@(_char.Culture ?? "")</div></td></tr>
        <tr><td class="p1"><div class="lbl">Profession:</div><div class="val">@(_char.Profession ?? "")</div></td></tr>
      </table>
    </td>
    <td class="p1 vt">
      @{
        // Table 5-2: FOS — max lift weight at each difficulty for this character
        // maxWeight = max(0, loadPct + 2×StBonus) % of body weight
        double _bodyLbs = _char.WeightKg.HasValue ? _char.WeightKg.Value * 2.20462 : 0;
        string FosWt(int loadPct)
        {
            int adjPct = loadPct + 2 * _stBonus;
            if (adjPct <= 0) return "—";
            if (_bodyLbs > 0)
            {
                double maxLb = adjPct / 100.0 * _bodyLbs;
                return $"{maxLb:F0} lb ({adjPct}%)";
            }
            return $"{adjPct}% body wt";
        }
      }
      <table class="t100 sf">
        <tr class="sh"><th class="tl">Difficulty</th><th>Mod</th><th>Max Weight</th></tr>
        @foreach (var (lp, lbl, mod) in _fosTable)
        {
          <tr>
            <td class="p1 bb">@lbl</td>
            <td class="p1 bb tc @(mod >= 0 ? "pos" : "neg")">@(mod >= 0 ? $"+{mod}" : mod.ToString())</td>
            <td class="p1 bb tr">@FosWt(lp)</td>
          </tr>
        }
        <tr><td colspan="3" class="p1 muted" style="font-size:6pt">Load = obj.wt% − 2×St bonus</td></tr>
        <tr><td colspan="3" class="p1"><span class="lbl">Size: </span>@(RaceRules.ByName.GetValueOrDefault(_char.Race ?? "")?.Size ?? "")</td></tr>
      </table>
    </td>
    <td class="p1 vt">
      @{
        int _waPercent    = Math.Max(0, 15 + 2 * _stBonus);
        // Armor enc% comes from the armor selection
        var _encArmorDef  = ArmorRules.ByAT.GetValueOrDefault(_char.ArmorType, ArmorRules.All[0]);
        double _armorEncPct = (_char.ArmorFullSuit ? _encArmorDef.FullEncPct
            : _encArmorDef.TorsoEncPct
              + ArmorRules.Helmet(_char.HelmetGrade).EncPct
              + ArmorRules.Vambrace(_char.VambracesGrade).EncPct
              + ArmorRules.Greave(_char.GreavesGrade).EncPct) * 100.0;
        int _armorEncInt   = (int)Math.Round(_armorEncPct);
        // Max pace from armor enc alone (items unknown)
        string _maxPace = _armorEncInt switch
        {
            <= 15 => "Dash",
            <= 30 => "Sprint",
            <= 45 => "Run",
            <= 60 => "Jog",
            <= 90 => "Walk",
            _     => "Creep",
        };
      }
      <table class="t100 sf">
        <tr><td class="p1 bb">
          Wt Allowance: <span class="fw pos">@_waPercent%</span><br/>
          <span class="muted">15% + 2×St(@(Fmt(_stBonus)))</span>
        </td></tr>
        <tr><td class="p1 bb">Carried (lbs): <div class="blank-line"></div></td></tr>
        <tr><td class="p1 bb">
          Armor Enc: <span class="fw @(_armorEncInt > _waPercent ? "neg" : "pos")">@_armorEncInt%</span><br/>
          <span class="muted">Penalty: @(_armorEncInt > _waPercent ? $"{_armorEncInt - _waPercent}%" : "none")</span>
        </td></tr>
        <tr><td class="p1 bb">
          Max Pace (armor): <span class="fw">@_maxPace</span><br/>
          <span class="muted">+ carried items reduce further</span>
        </td></tr>
        @{
          var _earlyArmorDef2 = ArmorRules.ByAT.GetValueOrDefault(_char.ArmorType, ArmorRules.All[0]);
          int _earlyRawManPen = _char.ArmorFullSuit
              ? _earlyArmorDef2.FullManPen
              : _earlyArmorDef2.TorsoManPen + ArmorRules.Greave(_char.GreavesGrade).ManPen;
          var _earlyMiaSk    = _char.Skills.FirstOrDefault(s => s.SkillName == "Maneuvering in Armor");
          int _earlyMiaRanks = _earlyMiaSk?.TotalRanks ?? 0;
          int _earlyMiaBonus = SkillRules.RankBonus(_earlyMiaRanks)
              + ((_earlyMiaSk?.IsProfessionalSkill ?? false) ? Math.Min(_earlyMiaRanks, 30) : 0)
              + ((_earlyMiaSk?.IsKnack ?? false) ? 5 : 0);
          int _earlyNetManPen = Math.Min(0, _earlyRawManPen + _earlyMiaBonus);
          int _earlyEncPen    = Math.Max(0, _armorEncInt - _waPercent);
          int _earlyTotalPen  = _earlyNetManPen - _earlyEncPen;
        }
        <tr><td class="p1">Total Maneuver Penalty:<br/>
          <span class="fw @(_earlyTotalPen < 0 ? "neg" : "")">@(_earlyTotalPen != 0 ? _earlyTotalPen.ToString() : "—")</span>
          <span class="muted"> (armor @_earlyNetManPen + enc −@_earlyEncPen)</span>
        </td></tr>
      </table>
    </td>
  </tr>
</table>

<!-- REALM row -->
<table class="tb mb1" style="width:40%">
  <tr>
    <td class="hdr" style="width:30%">Realm(s)</td>
    <td class="p1">@(_effectiveRealm ?? "")</td>
  </tr>
</table>

<!-- RACIAL TRAITS -->
@{
  var _racialTraits = _char.Race is not null ? RaceRules.GetTraits(_char.Race) : (IReadOnlyList<RacialTrait>)[];
}
@if (_racialTraits.Any())
{
<table class="t100 tb mb1">
  <tr>
    <td class="hdr">Racial Traits</td>
    <td class="p1" style="line-height:1.6">
      @foreach (var rt in _racialTraits)
      {
        <span class="badge @(rt.IsFlaw ? "bg-danger" : "bg-secondary") me-1">@rt.Label</span>
      }
    </td>
  </tr>
</table>
}

<!-- STATISTICS | QUICK INFO + MOVEMENT -->
<table class="t100 mb1" style="border-collapse:collapse">
  <tr>
    <td style="width:45%; vertical-align:top; padding:0; border:1px solid #2a2a5a">
      <div class="hdr">Statistics</div>
      <table class="t100 tb">
        <thead>
          <tr class="sh"><th class="tl">Stat</th><th>Potent.</th><th>Temp</th><th>Bonus</th><th>Racial</th><th>Special</th><th>Total</th></tr>
        </thead>
        <tbody>
          @{
            var statRace = _char.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var srd) ? srd : null;
          }
          @foreach (StatName sn in Enum.GetValues<StatName>())
          {
            var st = _char.Stats.FirstOrDefault(s => s.Stat == sn);
            int tmp = st?.Temporary ?? 0;
            int pot = st?.Potential ?? 0;
            int bon = SkillRules.StatBonus(tmp);
            int racial = statRace?.GetStatMod(sn) ?? 0;
            int special = st?.Special ?? 0;
            int total = bon + racial + special;
            string? statTip = tmp > 0
                ? $"Temp {tmp} → {Fmt(bon)}" +
                  (racial  != 0 ? $"\nRacial:  {Fmt(racial)}"  : "") +
                  (special != 0 ? $"\nSpecial: {Fmt(special)}" : "") +
                  $"\n──────────\n= {Fmt(total)}"
                : null;
            <tr>
              <td class="p1">@StatLabel(sn)</td>
              <td class="p1 tr">@(pot > 0 ? pot.ToString() : "")</td>
              <td class="p1 tr">@(tmp > 0 ? tmp.ToString() : "")</td>
              <td class="p1 tr">@(tmp > 0 ? Fmt(bon) : "")</td>
              <td class="p1 tr">@(racial  != 0 ? Fmt(racial)  : "")</td>
              <td class="p1 tr">@(special != 0 ? Fmt(special) : "")</td>
              <td class="p1 tr fw @(tmp > 0 ? (total >= 0 ? "pos" : "neg") : "")" data-tip="@statTip">@(tmp > 0 ? Fmt(total) : "")</td>
            </tr>
          }
        </tbody>
      </table>
    </td>
    <td style="width:55%; vertical-align:top; padding:0">
      <!-- Quick Info -->
      <table class="t100 tb mb0" style="border-bottom:0">
        <tr><td colspan="2" class="hdr">Quick Info</td></tr>
        <tr><td class="p1 bb">Base Move Rate (BMR)</td><td class="p1 bb tr fw">@_bmr</td></tr>
        <tr><td class="p1 bb">Initiative</td><td class="p1 bb tr fw">@Fmt(_quBonus)</td></tr>
        <tr><td class="p1 bb">Hit points</td><td class="p1 bb tr fw">@_hits</td></tr>
        <tr><td class="p1 bb">Endurance (for Fatigue)</td><td class="p1 bb tr fw">@Fmt(_endurance)</td></tr>
        <tr><td class="p1">Power</td><td class="p1 tr fw">@(_ppBonus > 0 ? _ppBonus.ToString() : "")</td></tr>
      </table>
      <!-- Movement -->
      @{
        int bmrCreep  = (int)Math.Round(_bmr * 0.75);
        int bmrWalk   = _bmr;
        int bmrJog    = _bmr * 2;
        int bmrRun    = _bmr * 3;
        int bmrSprint = _bmr * 4;
        int bmrDash   = _bmr * 5;
        int phCreep   = bmrCreep;
        int phWalk    = bmrCreep;
        int phJog     = (int)Math.Round(_bmr * 3.5);
        int phRun     = (int)Math.Round(_bmr * 3.5);
        int phSprint  = _bmr;
        int phDash    = (int)Math.Round(_bmr * 1.25);
      }
      <table class="t100 tb">
        <thead>
          <tr class="sh"><th>Pace</th><th>Per Round</th><th>Per Phase</th><th>Penalty/AP</th><th>Load Limit</th></tr>
        </thead>
        <tbody>
          <tr><td class="p1">Creep</td><td class="p1 tc">@bmrCreep ft</td><td class="p1 tc">@phCreep ft</td><td class="p1 tc">--</td><td class="p1 tc">--</td></tr>
          <tr><td class="p1">Walk</td><td class="p1 tc">@bmrWalk ft</td><td class="p1 tc">@phWalk ft</td><td class="p1 tc">-25 or 1 AP</td><td class="p1 tc">90%</td></tr>
          <tr><td class="p1">Jog</td><td class="p1 tc">@bmrJog ft</td><td class="p1 tc">@phJog ft</td><td class="p1 tc">-50 or 2 AP</td><td class="p1 tc">60%</td></tr>
          <tr><td class="p1">Run</td><td class="p1 tc">@bmrRun ft</td><td class="p1 tc">@phRun ft</td><td class="p1 tc">-75 or 3 AP</td><td class="p1 tc">45%</td></tr>
          <tr><td class="p1">Sprint</td><td class="p1 tc">@bmrSprint ft</td><td class="p1 tc">@phSprint ft</td><td class="p1 tc">4 AP</td><td class="p1 tc">30%</td></tr>
          <tr><td class="p1">Dash</td><td class="p1 tc">@bmrDash ft</td><td class="p1 tc">@phDash ft</td><td class="p1 tc">4+ AP</td><td class="p1 tc">15%</td></tr>
        </tbody>
      </table>
    </td>
  </tr>
</table>

<!-- WEAPON/ATTACK -->
<table class="t100 tb mb1">
  <thead>
    <tr class="sh"><th class="tl" style="width:35%">Weapon / Attack</th><th>Fumble</th><th>STR</th><th>Item Bonus</th><th>Skill</th><th>OB</th><th>Total</th></tr>
  </thead>
  <tbody>
  @{
    var combatCat  = SkillRules.Categories.First(c => c.Name == "Combat Training");
    var sheetRace  = _char.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var shRd) ? shRd : null;
    var weaponRows = _char.Skills
        .Where(s => WeaponRules.BySkill.ContainsKey(s.SkillName) && s.Specialization != null && s.PurchasedRanks > 0)
        .OrderBy(s => s.Id)
        .ToList();
  }
  @foreach (var ws in weaponRows)
  {
    var parentSk   = _char.Skills.FirstOrDefault(s => s.SkillName == ws.SkillName && s.Specialization == null);
    int cultural   = parentSk?.CulturalRanks ?? 0;
    bool wsPro     = parentSk?.IsProfessionalSkill ?? false;
    bool wsKnack   = parentSk?.IsKnack ?? false;
    int totalRanks = cultural + ws.PurchasedRanks;

    int catStat1   = SkillRules.StatBonus(Temp(combatCat.Stat1)) + (sheetRace?.GetStatMod(StatFromAbbr(combatCat.Stat1)) ?? 0);
    int catStat2   = SkillRules.StatBonus(Temp(combatCat.Stat2)) + (sheetRace?.GetStatMod(StatFromAbbr(combatCat.Stat2)) ?? 0);
    var skd        = combatCat.Skills.FirstOrDefault(s => s.Name == ws.SkillName);
    bool hasWepStat = skd?.SkillStat is not (null or "" or "R*" or "St or Ag");
    int wepStat    = hasWepStat ? SkillRules.StatBonus(Temp(skd!.SkillStat)) + (sheetRace?.GetStatMod(StatFromAbbr(skd.SkillStat)) ?? 0) : 0;

    int rankBonus  = SkillRules.RankBonus(totalRanks);
    int proBonus   = wsPro   ? Math.Min(totalRanks, 30) : 0;
    int knackBonus = wsKnack ? 5 : 0;
    int skill      = catStat1 + catStat2 + wepStat + rankBonus + proBonus + knackBonus;
    int strBonus   = SkillRules.StatBonus(Temp("St")) + (sheetRace?.GetStatMod(StatName.St) ?? 0);

    var wepTipParts = new System.Text.StringBuilder();
    wepTipParts.AppendLine($"{combatCat.Stat1}: {Fmt(catStat1)}  {combatCat.Stat2}: {Fmt(catStat2)}");
    if (hasWepStat) wepTipParts.AppendLine($"+{skd!.SkillStat} (weapon): {Fmt(wepStat)}");
    wepTipParts.AppendLine($"Ranks ({totalRanks}): {Fmt(rankBonus)}");
    if (proBonus   != 0) wepTipParts.AppendLine($"Prof: {Fmt(proBonus)}");
    if (knackBonus != 0) wepTipParts.AppendLine("Knack: +5");
    wepTipParts.Append($"──────────\n= {Fmt(skill)}");
    string wepTip = wepTipParts.ToString();

    <tr>
      <td class="p1">
        @ws.Specialization
        <span class="muted" style="font-size:7pt"> (@ws.SkillName)</span>
        @if (wsPro)   { <span class="muted" style="font-size:7pt"> Pro</span> }
        @if (wsKnack) { <span class="muted" style="font-size:7pt"> Knack</span> }
      </td>
      <td class="p1 tc muted">—</td>
      <td class="p1 tr">@Fmt(strBonus)</td>
      <td class="p1"></td>
      <td class="p1 tr @(skill >= 0 ? "pos" : "neg")">@Fmt(skill)</td>
      <td class="p1 tr fw" data-tip="@wepTip">@Fmt(skill)</td>
      <td class="p1 tr"></td>
    </tr>
  }
  @for (int i = weaponRows.Count; i < Math.Max(weaponRows.Count + 1, 4); i++) { <tr><td class="brow"></td><td></td><td></td><td></td><td></td><td></td><td></td></tr> }
  </tbody>
</table>

<!-- ARMOR -->
@{
  var _armorDef  = ArmorRules.ByAT.GetValueOrDefault(_char.ArmorType, ArmorRules.All[0]);
  var _helmDef   = ArmorRules.Helmet(_char.HelmetGrade);
  var _vambDef   = ArmorRules.Vambrace(_char.VambracesGrade);
  var _greaveDef = ArmorRules.Greave(_char.GreavesGrade);
  var _shieldDef = ArmorRules.Shield(_char.ShieldType);

  // Torso row values
  int _torsoManPen = _char.ArmorFullSuit ? _armorDef.FullManPen  : _armorDef.TorsoManPen;
  int _torsoWeight = _char.ArmorFullSuit ? _armorDef.FullWeight   : _armorDef.TorsoWeight;

  // Piecemeal pieces (zero when full suit — already included above)
  int _helmWeight   = _char.ArmorFullSuit ? 0 : _helmDef.Weight;
  int _vambWeight   = _char.ArmorFullSuit ? 0 : _vambDef.Weight;
  int _greaveWeight = _char.ArmorFullSuit ? 0 : _greaveDef.Weight;
  int _greaveManPen = _char.ArmorFullSuit ? 0 : _greaveDef.ManPen;
  int _percPen      = _helmDef.ManPen;    // perception penalty — always from helmet grade
  int _missilePen   = _vambDef.ManPen;   // ranged penalty — always from vambrace grade

  // Shield DB from Shield skill bonus
  var _shieldSk    = _char.Skills.FirstOrDefault(s => s.SkillName == "Shield");
  int _shieldSkRanks = _shieldSk?.TotalRanks ?? 0;
  // Combat Training stats: Ag+St, skill stat: St
  int _shAgBonus = SkillRules.StatBonus(Temp("Ag")) + (sheetRace?.GetStatMod(StatName.Ag) ?? 0);
  int _shStBonus = SkillRules.StatBonus(Temp("St")) + (sheetRace?.GetStatMod(StatName.St) ?? 0);
  int _shieldDb  = _char.ShieldType is not null and not "None"
      ? _shAgBonus + _shStBonus + _shStBonus
        + SkillRules.RankBonus(_shieldSkRanks)
        + ((_shieldSk?.IsProfessionalSkill ?? false) ? Math.Min(_shieldSkRanks, 30) : 0)
        + ((_shieldSk?.IsKnack ?? false) ? 5 : 0)
      : 0;

  // Maneuvering in Armor bonus (reduces movement manpen, but only to 0)
  var _miaSk     = _char.Skills.FirstOrDefault(s => s.SkillName == "Maneuvering in Armor");
  int _miaRanks  = _miaSk?.TotalRanks ?? 0;
  // Battle Expertise: no stats, so MiA bonus = rank bonus + pro + knack only
  int _miaBonus  = SkillRules.RankBonus(_miaRanks)
      + ((_miaSk?.IsProfessionalSkill ?? false) ? Math.Min(_miaRanks, 30) : 0)
      + ((_miaSk?.IsKnack ?? false) ? 5 : 0);

  // Total movement manpen (raw, before MiA)
  int _rawManPen  = _torsoManPen + _greaveManPen;
  // Net manpen after MiA (cannot be positive)
  int _netManPen  = Math.Min(0, _rawManPen + _miaBonus);

  int _totalWeight = _torsoWeight + _helmWeight + _vambWeight + _greaveWeight + _shieldDef.Weight;

  string ManPenFmt(int v) => v == 0 ? "—" : v.ToString();
  string WtFmt(int v)     => v == 0 ? "—" : $"{v} lb";
  string AtFmt(int v)     => v <= 1 ? "—" : v.ToString();
}
<table class="t100 mb1" style="border-collapse:collapse">
  <tr>
    <td style="width:72%; padding:0; vertical-align:top">
      <table class="t100 tb">
        <thead>
          <tr class="sh"><th class="tl">Area</th><th>Armor</th><th>AT</th><th>Man.Penalty</th><th>Weight</th><th>STR</th><th>DB</th><th>Casting Penalty</th></tr>
        </thead>
        <tbody>
          <tr>
            <td class="p1">Torso</td>
            <td class="p1">@(_armorDef.AT > 1 ? _armorDef.Name + (_char.ArmorFullSuit ? " (Full Suit)" : "") : "—")</td>
            <td class="p1 tc">@AtFmt(_armorDef.AT)</td>
            <td class="p1 tr">@ManPenFmt(_torsoManPen)</td>
            <td class="p1 tr">@WtFmt(_torsoWeight)</td>
            <td class="p1"></td><td class="p1"></td><td class="p1"></td>
          </tr>
          <tr>
            <td class="p1">Head</td>
            <td class="p1">@(_char.ArmorFullSuit && _armorDef.AT > 1 ? "Included" : (_helmDef.AT > 1 ? _helmDef.Grade + " Helm" : "—"))</td>
            <td class="p1 tc">@(_char.ArmorFullSuit ? AtFmt(_armorDef.AT) : AtFmt(_helmDef.AT))</td>
            <td class="p1 tr muted sf">@(ManPenFmt(_percPen))@(_percPen != 0 ? " perc." : "")</td>
            <td class="p1 tr">@WtFmt(_helmWeight)</td>
