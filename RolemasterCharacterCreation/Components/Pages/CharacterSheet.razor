          <tr>
            <td class="p1">Legs</td>
            <td class="p1">@(_char.ArmorFullSuit && _armorDef.AT > 1 ? "Included" : (_greaveDef.AT > 1 ? _greaveDef.Grade + " Greaves" : "—"))</td>
            <td class="p1 tc">@(_char.ArmorFullSuit ? AtFmt(_armorDef.AT) : AtFmt(_greaveDef.AT))</td>
