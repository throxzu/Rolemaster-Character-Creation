@code {
    [Parameter] public int Id { get; set; }

    Character? _char;
    bool _accessDenied;

    // ── Oracle state ─────────────────────────────────────────────────────────
    bool _oracleOpen;
    string _oracleInput = "";
    string _oracleResponse = "";
    bool _oracleThinking;
    CancellationTokenSource? _oracleCts;

    async Task AskOracleAsync()
    {
        if (string.IsNullOrWhiteSpace(_oracleInput) || _oracleThinking || _char is null) return;
        _oracleCts?.Cancel();
        _oracleCts = new CancellationTokenSource();
        _oracleResponse = "";
        _oracleThinking = true;
        var question = _oracleInput;
        _oracleInput = "";
        StateHasChanged();
        try
        {
            await foreach (var token in SheetAgent.AskAsync(_char, _char.Stats, question, _oracleCts.Token))
            {
                _oracleResponse += token;
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _oracleThinking = false;
            StateHasChanged();
        }
    }

    int _quBonus, _coBonus, _inBonus, _emBonus, _prBonus, _sdBonus;
    int _bmr, _ppBonus;

    record FosEntry(string Label, string Formula);
    static readonly FosEntry[] _fos =
    [
        new("Routine +30",    "Wt×0.2"),
        new("Easy +20",       "Wt×0.3"),
        new("Light +10",      "Wt×0.4"),
        new("Medium +0",      "Wt×0.5"),
        new("Hard -10",       "Wt×0.75"),
        new("Very Hard -20",  "Wt"),
        new("Ext.Hard -30",   "Wt×1.5"),
        new("Sheer Folly -50","Wt×2"),
        new("Absurd -70",     "Wt×3"),
        new("Nigh Imp. -100", "Wt×4"),
    ];

    protected override async Task OnInitializedAsync()
    {
        var auth   = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        var isGm   = auth.User.IsInRole(Roles.Gamemaster);

        _char = await Db.Characters
            .Include(c => c.Stats)
            .Include(c => c.Skills)
            .FirstOrDefaultAsync(c => c.Id == Id);

        if (_char is null) return;
        if (!isGm && _char.UserId != userId) { _accessDenied = true; return; }

        var raceBonus = _char.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var rbd) ? rbd : null;
        _quBonus = SkillRules.StatBonus(Temp("Qu")) + (raceBonus?.GetStatMod(StatName.Qu) ?? 0);
        _coBonus = SkillRules.StatBonus(Temp("Co")) + (raceBonus?.GetStatMod(StatName.Co) ?? 0);
        _inBonus = SkillRules.StatBonus(Temp("In")) + (raceBonus?.GetStatMod(StatName.In) ?? 0);
        _emBonus = SkillRules.StatBonus(Temp("Em")) + (raceBonus?.GetStatMod(StatName.Em) ?? 0);
        _prBonus = SkillRules.StatBonus(Temp("Pr")) + (raceBonus?.GetStatMod(StatName.Pr) ?? 0);
        _sdBonus = SkillRules.StatBonus(Temp("SD")) + (raceBonus?.GetStatMod(StatName.SD) ?? 0);
        _bmr     = 20 + (int)Math.Ceiling(_quBonus / 2.0);

        var pdSk = _char.Skills.FirstOrDefault(s => s.SkillName == "Power Development");
        _ppBonus = pdSk is not null ? SkillRules.RankBonus(pdSk.TotalRanks) : 0;
    }

    int Temp(string abbr)
    {
        if (_char is null) return 50;
        var sn = abbr switch
        {
            "Ag" => StatName.Ag, "Co" => StatName.Co, "Em" => StatName.Em,
            "In" => StatName.In, "Me" => StatName.Me, "Pr" => StatName.Pr,
            "Qu" => StatName.Qu, "Re" => StatName.Re, "SD" => StatName.SD,
            "St" => StatName.St, _ => StatName.Co
        };
        return _char.Stats.FirstOrDefault(s => s.Stat == sn)?.Temporary ?? 50;
    }

    static string Fmt(int v) => v >= 0 ? $"+{v}" : v.ToString();

    static StatName StatFromAbbr(string abbr) => abbr switch
    {
        "Ag" => StatName.Ag, "Co" => StatName.Co, "Em" => StatName.Em,
        "In" => StatName.In, "Me" => StatName.Me, "Pr" => StatName.Pr,
        "Qu" => StatName.Qu, "Re" => StatName.Re, "SD" => StatName.SD,
        "St" => StatName.St, _ => StatName.Co
    };

    static string StatLabel(StatName sn) => sn switch
    {
        StatName.Ag => "Agility (Ag)",
        StatName.Co => "Constitution (Co)",
        StatName.Em => "Empathy (Em)",
        StatName.In => "Intuition (In)",
        StatName.Me => "Memory (Me)",
        StatName.Pr => "Presence (Pr)",
        StatName.Qu => "Quickness (Qu)",
        StatName.Re => "Reasoning (Re)",
        StatName.SD => "Self-Discipline (SD)",
        StatName.St => "Strength (St)",
        _ => sn.ToString()
    };
}
