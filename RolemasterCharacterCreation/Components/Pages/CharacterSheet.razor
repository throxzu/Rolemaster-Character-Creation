@code {
    [Parameter] public int Id { get; set; }

    Character? _char;
    bool _accessDenied;
    bool _isGm;
    bool _isOwner;
    bool _canLevelUp => _char is not null && _isOwner && _char.CurrentXp >= 10000 * _char.Level;
    bool _playerCanAccessWizard => _char is not null &&
        ((_char.Level == 1 && _char.WizardStep < 5) ||   // initial creation in progress
         _char.LevelUpBaselineJson != null              ||   // level-up started but not finished
         _char.CurrentXp >= 10000 * _char.Level);           // enough XP to start a new level-up

    int _quBonus, _coBonus, _inBonus, _emBonus, _prBonus, _sdBonus, _stBonus;
    int _bmr, _ppBonus, _hits, _endurance, _realmStatBonus;
    string? _effectiveRealm;

    // Table 5-2: Feats of Strength — (loadPct, difficulty label, modifier)
    // Load = object weight as % of body weight, minus 2×Str bonus.
    static readonly (int LoadPct, string Label, int Mod)[] _fosTable =
    [
        (  5, "Casual",       +70),
        ( 10, "Simple",       +50),
        ( 20, "Routine",      +30),
        ( 30, "Easy",         +20),
        ( 40, "Light",        +10),
        ( 50, "Medium",         0),
        ( 75, "Hard",         -10),
        (100, "Very Hard",    -20),
        (150, "Ext. Hard",    -30),
        (200, "Sheer Folly",  -50),
        (300, "Absurd",       -70),
        (400, "Nigh Imp.",   -100),
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("initTooltips");
    }

    protected override async Task OnInitializedAsync()
    {
        var auth   = await AuthState.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        var isGm   = auth.User.IsInRole(Roles.Gamemaster);

        _char = await Db.Characters
            .Include(c => c.Stats)
            .Include(c => c.Skills)
            .Include(c => c.Talents)
            .Include(c => c.EquipmentItems)
            .FirstOrDefaultAsync(c => c.Id == Id);

        if (_char is null) return;
        if (!isGm && _char.UserId != userId) { _accessDenied = true; return; }
        _isGm   = isGm;
        _isOwner = isGm || _char.UserId == userId;

        var raceBonus = _char.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var rbd) ? rbd : null;
        _quBonus = SkillRules.StatBonus(Temp("Qu")) + (raceBonus?.GetStatMod(StatName.Qu) ?? 0);
        _coBonus = SkillRules.StatBonus(Temp("Co")) + (raceBonus?.GetStatMod(StatName.Co) ?? 0);
        _stBonus = SkillRules.StatBonus(Temp("St")) + (raceBonus?.GetStatMod(StatName.St) ?? 0);
        _inBonus = SkillRules.StatBonus(Temp("In")) + (raceBonus?.GetStatMod(StatName.In) ?? 0);
        _emBonus = SkillRules.StatBonus(Temp("Em")) + (raceBonus?.GetStatMod(StatName.Em) ?? 0);
        _prBonus = SkillRules.StatBonus(Temp("Pr")) + (raceBonus?.GetStatMod(StatName.Pr) ?? 0);
        _sdBonus = SkillRules.StatBonus(Temp("SD")) + (raceBonus?.GetStatMod(StatName.SD) ?? 0);
        _bmr = 20 + (int)Math.Ceiling(_quBonus / 2.0);

        // Body Development (Brawn: Co+SD, SkillStat: Co → stat bonus = Co+SD+Co)
        var bdSk    = _char.Skills.FirstOrDefault(s => s.SkillName == "Body Development");
        int bdRanks = bdSk?.TotalRanks ?? 0;
        int bdBonus = _coBonus + _sdBonus + _coBonus
                      + SkillRules.RankBonus(bdRanks)
                      + ((bdSk?.IsProfessionalSkill ?? false) ? Math.Min(bdRanks, 30) : 0)
                      + ((bdSk?.IsKnack ?? false) ? 5 : 0);
        int baseHits = raceBonus?.BaseHits ?? 25;
        _hits      = (int)Math.Round((baseHits + bdBonus) * (raceBonus?.HitMultiplier ?? 1.0f));
        _endurance = bdBonus + (raceBonus?.EnduranceBonus ?? 0);

        // Resolve effective realm: stored value, else derive from profession (Core Law §2.4)
        _effectiveRealm = _char.Realm
            ?? ProfessionRules.ByName.GetValueOrDefault(_char.Profession ?? "")?.Realm;
        _realmStatBonus = SkillRules.RealmBonus(_effectiveRealm, _inBonus, _emBonus, _prBonus);

        // Power Development (Power Manipulation: R*+R*, SkillStat: Co)
        var pdSk    = _char.Skills.FirstOrDefault(s => s.SkillName == "Power Development");
        int pdRanks = pdSk?.TotalRanks ?? 0;
        int pdBonus = SkillRules.RankBonus(pdRanks)
                      + ((pdSk?.IsProfessionalSkill ?? false) ? Math.Min(pdRanks, 30) : 0)
                      + ((pdSk?.IsKnack ?? false) ? 5 : 0);
        if (_effectiveRealm is not null)
        {
            int realmBonus = _realmStatBonus;
            _ppBonus = realmBonus * 2 + _coBonus + pdBonus;
        }
        else
        {
            _ppBonus = 0;
        }
    }

    async Task SaveXpAsync(ChangeEventArgs e)
    {
        if (_char is null) return;
        if (int.TryParse(e.Value?.ToString(), out int xp))
        {
            _char.CurrentXp = Math.Max(0, xp);
            await Db.SaveChangesAsync();
        }
    }

    async Task LevelUpAsync()
    {
        if (_char is null) return;
        // Freeze skill-rank and stat baselines so the wizard can't be gamed by restarting
        _char.LevelUpBaselineJson = System.Text.Json.JsonSerializer.Serialize(
            _char.Skills.Select(s => new { s.SkillName, s.Specialization, s.Category, s.PurchasedRanks }));
        _char.StatBaselineJson = System.Text.Json.JsonSerializer.Serialize(
            _char.Stats.ToDictionary(s => s.Stat.ToString(), s => new[] { s.Temporary, s.Potential }));
        _char.Level++;          // pre-increment so wizard detects _isLevelUp = Level > 1
        _char.WizardStep = 1;
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/character/{Id}/wizard");
    }

    int Temp(string abbr)
    {
        if (_char is null) return 50;
        var sn = abbr switch
        {
            "Ag" => StatName.Ag, "Co" => StatName.Co, "Em" => StatName.Em,
            "In" => StatName.In, "Me" => StatName.Me, "Pr" => StatName.Pr,
            "Qu" => StatName.Qu, "Re" => StatName.Re, "SD" => StatName.SD,
            "St" => StatName.St, _ => StatName.Co
        };
        return _char.Stats.FirstOrDefault(s => s.Stat == sn)?.Temporary ?? 50;
    }

    static string Fmt(int v) => v >= 0 ? $"+{v}" : v.ToString();

    static string FmtHeight(int cm)
    {
        double totalIn = cm / 2.54;
        int feet = (int)(totalIn / 12);
        int inches = (int)Math.Round(totalIn % 12);
        if (inches == 12) { feet++; inches = 0; }
        return $"{cm} cm ({feet}'{inches}\")";
    }

    static string FmtWeight(int kg)
    {
        int lb = (int)Math.Round(kg * 2.20462);
        return $"{kg} kg ({lb} lb)";
    }

    static StatName StatFromAbbr(string abbr) => abbr switch
    {
        "Ag" => StatName.Ag, "Co" => StatName.Co, "Em" => StatName.Em,
        "In" => StatName.In, "Me" => StatName.Me, "Pr" => StatName.Pr,
        "Qu" => StatName.Qu, "Re" => StatName.Re, "SD" => StatName.SD,
        "St" => StatName.St, _ => StatName.Co
    };

    static string StatLabel(StatName sn) => sn switch
    {
        StatName.Ag => "Agility (Ag)",
        StatName.Co => "Constitution (Co)",
        StatName.Em => "Empathy (Em)",
        StatName.In => "Intuition (In)",
        StatName.Me => "Memory (Me)",
        StatName.Pr => "Presence (Pr)",
        StatName.Qu => "Quickness (Qu)",
        StatName.Re => "Reasoning (Re)",
        StatName.SD => "Self-Discipline (SD)",
        StatName.St => "Strength (St)",
        _ => sn.ToString()
    };

    static double ItemWeight(string name) =>
        EquipmentRules.General.FirstOrDefault(i => i.Name == name)?.WeightLbs
        ?? EquipmentRules.Weapons.FirstOrDefault(i => i.Name == name)?.WeightLbs
        ?? 0;
}
