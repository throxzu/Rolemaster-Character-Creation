<!-- ═══════════ SKILLS PAGES ═══════════ -->
<table class="t100 sk-table tb">
  <thead>
    <tr class="sh">
      <th style="width:14px">Prof</th>
      <th class="tl" style="min-width:120px">Skill Category / Name</th>
      <th style="width:80px">Specialization</th>
      <th style="width:40px">Culture Ranks</th>
      <th style="width:65px">Stats</th>
      <th style="width:38px">Stat Bonus</th>
      <th style="width:38px">Total Ranks</th>
      <th style="width:38px">Rank Bonus</th>
      <th style="width:38px">Prof Bonus</th>
      <th style="width:48px">Special/ Knack</th>
      <th style="width:42px">Total Bonus</th>
      <th style="width:32px">DP Cost</th>
    </tr>
  </thead>
  <tbody>
  @{
    var profDef = ProfessionRules.ByName.GetValueOrDefault(_char.Profession ?? "");
    var skByName = _char.Skills.Where(s => s.Specialization == null).ToDictionary(s => s.SkillName, s => s);
  }
  @foreach (var cat in SkillRules.Categories)
  {
    string ck = cat.Name switch
    {
        "Combat Training" => "Combat Training 1",
        "Spellcasting"    => "Spells: Base/Open",
        _                 => cat.Name
    };
    string dp = profDef is not null && profDef.Costs.TryGetValue(ck, out var ccc)
        ? $"{ccc.First}/{ccc.Second}" : "—";
    int csb1 = cat.NoStats ? 0 : (cat.Stat1 == "R*" ? _realmStatBonus : SkillRules.StatBonus(Temp(cat.Stat1)));
    int csb2 = cat.NoStats ? 0 : (cat.Stat2 == "R*" ? _realmStatBonus : (cat.Stat2 == cat.Stat1 ? csb1 : SkillRules.StatBonus(Temp(cat.Stat2))));
    int catSum = csb1 + csb2;
    string catStatStr = cat.NoStats ? "-" : $"{cat.Stat1}+{cat.Stat2}";

    <tr class="sk-cat">
      <td></td>
      <td class="p1 fw">@cat.Name</td>
      <td></td>
      <td></td>
      <td class="p1 tc">@catStatStr ↑</td>
      <td></td><td></td><td></td><td></td><td></td><td></td>
      <td class="p1 tc">@dp</td>
    </tr>

    @foreach (var skd in cat.Skills)
    {
      skByName.TryGetValue(skd.Name, out var csk);
      int cult  = csk?.CulturalRanks ?? 0;
      int purch = csk?.PurchasedRanks ?? 0;
      int tot   = cult + purch;
      bool isPro   = csk?.IsProfessionalSkill ?? false;
      bool isKnack = csk?.IsKnack ?? false;

      int sskBonus = (cat.NoStats || skd.SkillStat is "" or "R*")
          ? 0 : SkillRules.StatBonus(Temp(skd.SkillStat));
      int statTotal = cat.NoStats ? 0 : catSum + sskBonus;
      int rkBon  = tot > 0 ? SkillRules.RankBonus(tot) : 0;
      int proBon = isPro   ? Math.Min(tot, 30) : 0;
      int knBon  = isKnack ? 5 : 0;
      int ttlBon = statTotal + rkBon + proBon + knBon;

      string? skTip = null;
      if (tot > 0 || isKnack)
      {
          var sb = new System.Text.StringBuilder();
          if (!cat.NoStats)
          {
              sb.AppendLine($"{cat.Stat1}+{cat.Stat2}: {Fmt(catSum)}");
              if (skd.SkillStat is not ("" or "R*" or "St or Ag"))
                  sb.AppendLine($"+{skd.SkillStat}: {Fmt(sskBonus)}");
          }
          if (tot > 0) sb.AppendLine($"Ranks ({tot}): {Fmt(rkBon)}");
          if (proBon != 0) sb.AppendLine($"Prof: {Fmt(proBon)}");
          if (knBon  != 0) sb.AppendLine("Knack: +5");
          sb.Append($"──────────\n= {Fmt(ttlBon)}");
          skTip = sb.ToString();
      }

      string statsCell = cat.NoStats ? "-"
          : (skd.SkillStat is "" or "R*" ? "←" : $"←+{skd.SkillStat}→");

      <tr class="sk-row @(isPro ? "sk-pro" : "") @(isKnack ? "sk-knack" : "")">
        <td class="tc">@(isPro ? "■" : "□")</td>
        <td class="p1">
          <span data-bs-toggle="tooltip" data-bs-title="@skd.Description" data-bs-placement="right">@skd.Name</span>
          @if (skd.Specialized) { <span class="spec-tag">(spec.)</span> }
        </td>
        <td class="@(skd.Specialized ? "spec-gray" : "") p1"></td>
        <td class="p1 tr">@(cult > 0 ? cult.ToString() : "")</td>
        <td class="p1 tc sk-stats">@statsCell</td>
        <td class="p1 tr">@(tot > 0 && !cat.NoStats ? Fmt(statTotal) : "")</td>
        <td class="p1 tr">@(tot > 0 ? tot.ToString() : "")</td>
        <td class="p1 tr">@(tot > 0 ? Fmt(rkBon) : "")</td>
        <td class="p1 tr">@(proBon > 0 ? Fmt(proBon) : "")</td>
        <td class="p1 tr">@(knBon > 0 ? "+5" : "")</td>
        <td class="p1 tr fw @(tot > 0 || isKnack ? (ttlBon >= 0 ? "pos" : "neg") : "")" data-tip="@skTip">
          @(tot > 0 || isKnack ? Fmt(ttlBon) : "")
        </td>
        <td class="p1 tc muted">□□</td>
      </tr>
    }
  }
  </tbody>
</table>

<!-- ═══════════ PAGE BREAK ═══════════ -->
<div class="pgbrk"></div>

<!-- ═══════════ EQUIPMENT PAGE ═══════════ -->
@{
