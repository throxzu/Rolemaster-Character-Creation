            <td class="p1"></td>
          </tr>
        </tbody>
      </table>
    </td>
    <td style="width:28%; vertical-align:top; border:1px solid #2a2a5a; padding:2px 4px">
      <div class="arm-side">Perception Pen: <span class="fw @(_percPen < 0 ? "neg" : "")">@(_percPen != 0 ? _percPen.ToString() : "—")</span></div>
      <div class="arm-side gcell"></div>
