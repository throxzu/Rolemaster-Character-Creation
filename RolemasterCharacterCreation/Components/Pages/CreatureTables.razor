@page "/creature-tables"
@rendermode InteractiveServer
@using RolemasterCharacterCreation.Identity
@attribute [Authorize(Roles = Roles.Gamemaster)]
@using RolemasterCharacterCreation.Models
@using RolemasterCharacterCreation.Services
@inject CreatureTableService Tables

<PageTitle>Creature Tables</PageTitle>

<div class="container-fluid mt-3">
    <h2 class="mb-3">Creature Tables</h2>

    <div class="row g-3">
        <!-- ── Left: searchable, grouped list ── -->
        <div class="col-md-4 col-lg-3">
            <div class="qp-card p-2 mb-2">
                <input class="form-control form-control-sm" placeholder="Search creature tables…"
                       @bind="_search" @bind:event="oninput" />
            </div>
            <div class="ct-list qp-card p-0">
                @foreach (var grp in Filtered.GroupBy(t => t.Category).OrderBy(g => g.Key))
                {
                    <div class="ct-group-header">@grp.Key</div>
                    @foreach (var tbl in grp.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <div class="ct-list-item @(_selected == tbl ? "active" : "")"
                             @onclick="() => _selected = tbl">
                            @tbl.Name
                        </div>
                    }
                }
                @if (!Filtered.Any())
                {
                    <div class="p-3 text-muted">No tables match.</div>
                }
            </div>
        </div>

        <!-- ── Right: selected table ── -->
        <div class="col-md-8 col-lg-9">
            @if (_selected is { } t)
            {
                <div class="qp-card p-4">
                    <div class="d-flex flex-wrap align-items-baseline gap-2 mb-3">
                        <h3 class="ct-title mb-0">@t.Name</h3>
                        <span class="ct-meta">@t.Book · @t.Category</span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(t.Notes))
                    {
                        <div class="ct-notes mb-3">@t.Notes</div>
                    }

                    <div class="ct-grid-wrap">
                        <table class="table table-sm table-bordered ct-grid mb-0">
                            <thead>
                                <tr>
                                    @foreach (var c in t.Columns)
                                    {
                                        <th>@c</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in t.Rows)
                                {
                                    <tr>
                                        @for (var i = 0; i < t.Columns.Count; i++)
                                        {
                                            var val = i < row.Count ? row[i] : "";
                                            @if (i == 0 && !string.IsNullOrWhiteSpace(val))
                                            {
                                                <td>
                                                    <a class="ct-name-link"
                                                       href="@($"/gm/creatures?name={Uri.EscapeDataString(val)}")"
                                                       target="_blank"
                                                       title="Open full description for @val">@val</a>
                                                </td>
                                            }
                                            else
                                            {
                                                <td>@val</td>
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="qp-card p-4 text-muted text-center">Select a creature table.</div>
            }
        </div>
    </div>
</div>

<style>
    .ct-list { max-height: calc(100vh - 230px); overflow-y: auto; display: flex; flex-direction: column; }
    .ct-group-header { padding: 8px 14px 4px; font-size: .72rem; font-weight: 700;
                       text-transform: uppercase; letter-spacing: .06em; color: var(--qp-teal);
                       background: var(--qp-bg-panel-alt); border-bottom: 1px solid var(--qp-border-panel); }
    .ct-list-item { padding: 7px 14px; border-bottom: 1px solid var(--qp-border-panel);
                    cursor: pointer; color: var(--qp-text-primary); transition: background .12s; }
    .ct-list-item:hover  { background: var(--qp-bg-panel-alt); }
    .ct-list-item.active { background: var(--qp-blue); color: #fff; }
    .ct-title { color: var(--qp-teal); font-weight: 700; letter-spacing: .03em; }
    .ct-meta { color: var(--qp-text-muted); font-size: .82rem; }
    .ct-notes { color: var(--qp-text-muted); font-size: .88rem; line-height: 1.6;
                white-space: pre-line; }
    .ct-grid-wrap { max-height: calc(100vh - 300px); overflow: auto; }
    .ct-grid { font-size: .8rem; }
    .ct-grid th { position: sticky; top: 0; z-index: 1; background: var(--qp-bg-panel);
                  color: var(--qp-text-label); border-color: var(--qp-border-panel) !important;
                  white-space: nowrap; }
    .ct-grid td { border-color: var(--qp-border-panel) !important; padding: 4px 8px;
                  vertical-align: top; line-height: 1.4; }
    .ct-grid td:first-child { white-space: nowrap; font-weight: 600; }
    .ct-name-link { color: var(--qp-teal); text-decoration: none; }
    .ct-name-link:hover { text-decoration: underline; cursor: pointer; }
</style>

@code {
    [SupplyParameterFromQuery(Name = "table")]
    public string? TableName { get; set; }

    private string _search = "";
    private ReferenceTable? _selected;

    private IEnumerable<ReferenceTable> Filtered => Tables.Search(_search);

    protected override void OnInitialized() =>
        _selected = (TableName is not null ? Tables.ByName(TableName) : null)
            ?? Tables.All.FirstOrDefault();
}
