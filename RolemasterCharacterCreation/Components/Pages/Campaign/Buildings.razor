@page "/campaign/buildings"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using RolemasterCharacterCreation.Data
@inject AppDbContext Db
@inject BuildingMapService Maps
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Buildings</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Buildings</h2>
    @if (_isGm)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" @onclick="() => _showUpload = !_showUpload">
                @(_showUpload ? "Close" : "+ Upload")
            </button>
            <a class="btn btn-outline-secondary btn-sm" href="/campaign/building-categories">Legend</a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_isGm && _showUpload)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a new building</h5>
            <p class="text-muted small mb-3">
                Upload a <a href="https://watabou.itch.io/" target="_blank" rel="noopener">Watabou
                building</a> export (<code>.svg</code>) — a multi-floor "lonely house" map. It's shown
                exactly as drawn, one floor at a time, with an interactive grid overlaid so you can
                mark legends and reveal it square by square.
            </p>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Building name</label>
                    <input class="form-control" @bind="_uploadName" placeholder="e.g. The Lonely House" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Map file (.svg)</label>
                    <InputFile class="form-control" accept=".svg,image/svg+xml" OnChange="OnFileSelected" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" disabled="@(!_canUpload)" @onclick="UploadAsync">
                        Upload Building
                    </button>
                </div>
            </div>
            <div class="alert alert-info py-2 px-3 small mb-0 mt-3">
                <strong>Best results &mdash; in the Watabou building generator, set:</strong>
                <ul class="mb-2 ps-3">
                    <li><strong>Layers &rarr; Grid:</strong> Hidden</li>
                    <li><strong>Layers &rarr; Doors:</strong> Simple</li>
                    <li><strong>Layers &rarr; Labels:</strong> Hidden</li>
                    <li><strong>Layers &rarr; Roof:</strong> Hidden</li>
                    <li><strong>Layers &rarr; Props:</strong> Off</li>
                    <li><strong>Style &rarr; Preset:</strong> Blueprint</li>
                    <li><strong>Export &rarr; Advanced:</strong> Floors <strong>On</strong>, As Table &rarr; Max &times; 1, Dots per cell: Max, Format: <strong>SVG</strong></li>
                </ul>
                Then export and upload the <code>.svg</code> here. The app shows each floor one at a
                time and overlays its own grid for revealing and legends.
            </div>
            @if (_pendingSvg is not null)
            {
                <div class="small text-success mt-2">Map file loaded &mdash; ready to upload.</div>
            }
        </div>
    </div>
}

@if (!_showUpload)
{
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control qp-input" placeholder="Search by name…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        @if (_placeOptions.Any())
        {
            <div class="col-md-4">
                <select class="form-select qp-input" @bind="_placeFilter">
                    <option value="">All towns &amp; villages</option>
                    @foreach (var name in _placeOptions)
                    {
                        <option value="@name">@name</option>
                    }
                    <option value="@NoneFilter">— Unassigned —</option>
                </select>
            </div>
        }
    </div>
}

@if (_showUpload)
{
    @* Upload mode: only the upload card above is shown. *@
}
else if (!Filtered.Any())
{
    <p class="text-muted">
        @(_buildings.Count == 0
            ? (_isGm ? "No buildings yet. Use + Upload above." : "No buildings yet. Ask your Gamemaster to add one.")
            : "No matches for your search.")
    </p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:8rem">Locations</th>
                <th>Town / Village</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var b in Filtered)
            {
                @if (_editId == b.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="_editName" placeholder="Building name" /></td>
                        <td>@b.Locations.Count</td>
                        <td class="@(PlaceFor(b) is null ? "text-muted" : null)">@(PlaceFor(b) ?? "—")</td>
                        <td><input class="form-control form-control-sm" @bind="_editDescription" placeholder="Description (optional)" /></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEditAsync(b)">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _editId = null">Cancel</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@b.Name</td>
                        <td>@b.Locations.Count</td>
                        <td class="@(PlaceFor(b) is null ? "text-muted" : null)">@(PlaceFor(b) ?? "Unassigned")</td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(b.Description) ? "—" : b.Description)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary me-1" href="/campaign/buildings/@b.Id">Open</a>
                            @if (_isGm)
                            {
                                @if (_deleteId == b.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteAsync(b)">Delete?</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _deleteId = null">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(b)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = b.Id">Delete</button>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private const long MaxBytes = 8 * 1024 * 1024;

    private List<BuildingMap> _buildings = [];
    private Dictionary<int, List<string>> _buildingPlaces = [];
    private List<string> _placeOptions = [];
    private bool _isGm;
    private string _search = "";
    private bool _showUpload;

    private const string NoneFilter = "::none::";
    private string _placeFilter = "";

    private IEnumerable<BuildingMap> Filtered =>
        _buildings.Where(b =>
            (string.IsNullOrWhiteSpace(_search)
                || (b.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                || (b.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
            && MatchesPlace(b));

    private bool MatchesPlace(BuildingMap b)
    {
        if (string.IsNullOrEmpty(_placeFilter)) return true;
        var has = _buildingPlaces.TryGetValue(b.Id, out var names) && names.Count > 0;
        return _placeFilter == NoneFilter ? !has : has && names!.Contains(_placeFilter);
    }
    private string? _currentUserId;
    private string _uploadName = "";
    private string? _pendingSvg;
    private int? _deleteId;
    private int? _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string? _message;
    private bool _isError;

    private bool _canUpload => !string.IsNullOrWhiteSpace(_uploadName) && _pendingSvg is not null;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isGm = auth.User.IsInRole(Roles.Gamemaster);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _buildings = await Db.BuildingMaps
            .Include(b => b.Locations)
            .OrderBy(b => b.Name)
            .ToListAsync();

        // Which town(s)/village(s) link to each building, via their marked places.
        var townLinks = await Db.TownLocations
            .Where(l => l.LinkedBuildingId != null)
            .Select(l => new { BuildingId = l.LinkedBuildingId!.Value, Place = l.Town!.Name })
            .ToListAsync();
        var villageLinks = await Db.VillageLocations
            .Where(l => l.LinkedBuildingId != null)
            .Select(l => new { BuildingId = l.LinkedBuildingId!.Value, Place = l.Village!.Name })
            .ToListAsync();
        _buildingPlaces = townLinks.Concat(villageLinks)
            .GroupBy(x => x.BuildingId)
            .ToDictionary(g => g.Key, g => g.Select(x => x.Place).Distinct().OrderBy(n => n).ToList());
        _placeOptions = _buildingPlaces.Values.SelectMany(v => v).Distinct().OrderBy(n => n).ToList();
    }

    private string? PlaceFor(BuildingMap b) =>
        _buildingPlaces.TryGetValue(b.Id, out var n) && n.Count > 0 ? string.Join(", ", n) : null;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingSvg = null;
        _message = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(MaxBytes));
            var svg = await reader.ReadToEndAsync();
            if (!Maps.IsValid(svg, out var error))
            {
                SetMessage(error ?? "Unrecognized map file.", error: true);
                return;
            }
            _pendingSvg = svg;
            if (string.IsNullOrWhiteSpace(_uploadName))
                _uploadName = Path.GetFileNameWithoutExtension(e.File.Name);
        }
        catch (IOException)
        {
            SetMessage("That file is too large (max 8 MB).", error: true);
        }
    }

    private async Task UploadAsync()
    {
        if (!_isGm || !_canUpload) return;

        var building = new BuildingMap
        {
            Name = _uploadName.Trim(),
            RawSvg = _pendingSvg!,
            CreatedByUserId = _currentUserId,
        };
        Db.BuildingMaps.Add(building);
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/campaign/buildings/{building.Id}");
    }

    private void BeginEdit(BuildingMap building)
    {
        _editId = building.Id;
        _editName = building.Name;
        _editDescription = building.Description ?? "";
        _deleteId = null;
    }

    private async Task SaveEditAsync(BuildingMap building)
    {
        if (!_isGm || string.IsNullOrWhiteSpace(_editName)) return;
        building.Name = _editName.Trim();
        building.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
        await Db.SaveChangesAsync();
        _editId = null;
        SetMessage($"Renamed to {building.Name}.");
    }

    private async Task DeleteAsync(BuildingMap building)
    {
        if (!_isGm) return;
        Db.BuildingMaps.Remove(building);
        await Db.SaveChangesAsync();
        _deleteId = null;
        SetMessage($"Deleted {building.Name}.");
        await LoadAsync();
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }
}
