@page "/campaign/villages"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using RolemasterCharacterCreation.Data
@inject AppDbContext Db
@inject TownMapService Maps
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Villages</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Villages</h2>
    @if (_isGm)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" @onclick="() => _showUpload = !_showUpload">
                @(_showUpload ? "Close" : "+ Upload")
            </button>
            <a class="btn btn-outline-secondary btn-sm" href="/campaign/village-categories">Legend</a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_isGm && _showUpload)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a new village</h5>
            <p class="text-muted small mb-3">
                Upload a village generator export (Watabou / MFCG <code>.json</code>). It will be
                drawn as an interactive map you can color-code.
            </p>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Village name</label>
                    <input class="form-control" @bind="_uploadName" placeholder="e.g. Oakhollow" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Map file (.json)</label>
                    <InputFile class="form-control" accept=".json,application/json" OnChange="OnFileSelected" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" disabled="@(!_canUpload)" @onclick="UploadAsync">
                        Upload Village
                    </button>
                </div>
            </div>
            <div class="alert alert-info py-2 px-3 small mb-0 mt-3">
                <strong>Best results &mdash; in the <a href="https://watabou.github.io/village-generator/" target="_blank" rel="noopener">Village Generator</a>, set:</strong>
                <ul class="mb-2 ps-3">
                    <li><strong>Layers &rarr; Title:</strong> Off</li>
                </ul>
                Then use <strong>Export &rarr; JSON</strong> (not the image) and upload the <code>.json</code> here.
                You colour-code the village in the app afterwards.
            </div>
            @if (_pendingJson is not null)
            {
                <div class="small text-success mt-2">Map file loaded &mdash; ready to upload.</div>
            }
        </div>
    </div>
}

@if (!_showUpload)
{
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control qp-input" placeholder="Search by name…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select qp-input" @bind="_mapFilter">
                <option value="">All world maps</option>
                @foreach (var name in _mapOptions)
                {
                    <option value="@name">@name</option>
                }
                <option value="@NoneFilter">— Unassigned —</option>
            </select>
        </div>
    </div>
}

@if (_showUpload)
{
    @* Upload mode: only the upload card above is shown. *@
}
else if (!Filtered.Any())
{
    <p class="text-muted">
        @(_villages.Count == 0
            ? (_isGm ? "No villages yet. Use + Upload above." : "No villages yet. Ask your Gamemaster to add one.")
            : "No matches for your search.")
    </p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:8rem">Locations</th>
                <th>World map</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var v in Filtered)
            {
                @if (_editId == v.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="_editName" placeholder="Village name" /></td>
                        <td>@v.Locations.Count</td>
                        <td class="@(MapFor(v) is null ? "text-muted" : null)">@(MapFor(v) ?? "—")</td>
                        <td><input class="form-control form-control-sm" @bind="_editDescription" placeholder="Description (optional)" /></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEditAsync(v)">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _editId = null">Cancel</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@v.Name</td>
                        <td>@v.Locations.Count</td>
                        <td class="@(MapFor(v) is null ? "text-muted" : null)">@(MapFor(v) ?? "Unassigned")</td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(v.Description) ? "—" : v.Description)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary me-1" href="/campaign/villages/@v.Id">Open</a>
                            @if (_isGm)
                            {
                                @if (_deleteId == v.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteAsync(v)">Delete?</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _deleteId = null">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(v)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = v.Id">Delete</button>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private const long MaxBytes = 5 * 1024 * 1024;

    private List<Village> _villages = [];
    private Dictionary<int, List<string>> _villageMaps = [];
    private List<string> _mapOptions = [];
    private bool _isGm;
    private string _search = "";
    private bool _showUpload;

    private const string NoneFilter = "::none::";
    private string _mapFilter = "";

    private IEnumerable<Village> Filtered =>
        _villages.Where(v =>
            (string.IsNullOrWhiteSpace(_search)
                || (v.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                || (v.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
            && MatchesMap(v));

    private bool MatchesMap(Village v)
    {
        if (string.IsNullOrEmpty(_mapFilter)) return true;
        var has = _villageMaps.TryGetValue(v.Id, out var names) && names.Count > 0;
        return _mapFilter == NoneFilter ? !has : has && names!.Contains(_mapFilter);
    }
    private string? _currentUserId;
    private string _uploadName = "";
    private string? _pendingJson;
    private int? _deleteId;
    private int? _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string? _message;
    private bool _isError;

    private bool _canUpload => !string.IsNullOrWhiteSpace(_uploadName) && _pendingJson is not null;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isGm = auth.User.IsInRole(Roles.Gamemaster);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _villages = await Db.Villages
            .Include(v => v.Locations)
            .OrderBy(v => v.Name)
            .ToListAsync();

        // Which world map(s) link to each village, via their points of interest.
        var links = await Db.WorldLocations
            .Where(l => l.LinkedVillageId != null)
            .Select(l => new { VillageId = l.LinkedVillageId!.Value, MapName = l.WorldMap!.Name })
            .ToListAsync();
        _villageMaps = links
            .GroupBy(x => x.VillageId)
            .ToDictionary(g => g.Key, g => g.Select(x => x.MapName).Distinct().OrderBy(n => n).ToList());
        _mapOptions = _villageMaps.Values.SelectMany(v => v).Distinct().OrderBy(n => n).ToList();
    }

    private string? MapFor(Village v) =>
        _villageMaps.TryGetValue(v.Id, out var n) && n.Count > 0 ? string.Join(", ", n) : null;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingJson = null;
        _message = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(MaxBytes));
            var json = await reader.ReadToEndAsync();
            if (!Maps.IsValid(json, out var error))
            {
                SetMessage(error ?? "Unrecognized map file.", error: true);
                return;
            }
            _pendingJson = json;
            if (string.IsNullOrWhiteSpace(_uploadName))
                _uploadName = Path.GetFileNameWithoutExtension(e.File.Name);
        }
        catch (IOException)
        {
            SetMessage("That file is too large (max 5 MB).", error: true);
        }
    }

    private async Task UploadAsync()
    {
        if (!_isGm || !_canUpload) return;

        var village = new Village
        {
            Name = _uploadName.Trim(),
            RawJson = _pendingJson!,
            CreatedByUserId = _currentUserId,
        };
        Db.Villages.Add(village);
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/campaign/villages/{village.Id}");
    }

    private void BeginEdit(Village village)
    {
        _editId = village.Id;
        _editName = village.Name;
        _editDescription = village.Description ?? "";
        _deleteId = null;
    }

    private async Task SaveEditAsync(Village village)
    {
        if (!_isGm || string.IsNullOrWhiteSpace(_editName)) return;
        village.Name = _editName.Trim();
        village.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
        await Db.SaveChangesAsync();
        _editId = null;
        SetMessage($"Renamed to {village.Name}.");
    }

    private async Task DeleteAsync(Village village)
    {
        if (!_isGm) return;
        Db.Villages.Remove(village);
        await Db.SaveChangesAsync();
        _deleteId = null;
        SetMessage($"Deleted {village.Name}.");
        await LoadAsync();
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }
}
