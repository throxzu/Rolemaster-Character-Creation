@page "/campaign/caves"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using RolemasterCharacterCreation.Data
@inject AppDbContext Db
@inject CaveMapService Maps
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Caves</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Caves</h2>
    @if (_isGm)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" @onclick="() => _showUpload = !_showUpload">
                @(_showUpload ? "Close" : "+ Upload")
            </button>
            <a class="btn btn-outline-secondary btn-sm" href="/campaign/cave-categories">Legend</a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_isGm && _showUpload)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a new cave</h5>
            <p class="text-muted small mb-3">
                Upload a <a href="https://watabou.itch.io/caves" target="_blank" rel="noopener">Watabou
                Caves</a> export (<code>.svg</code>). It's shown exactly as drawn, with an interactive grid
                overlaid so you can mark legends and reveal it square by square.
            </p>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Cave name</label>
                    <input class="form-control" @bind="_uploadName" placeholder="e.g. Sorrowlake Hollows" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Map file (.svg)</label>
                    <InputFile class="form-control" accept=".svg,image/svg+xml" OnChange="OnFileSelected" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" disabled="@(!_canUpload)" @onclick="UploadAsync">
                        Upload Cave
                    </button>
                </div>
            </div>
            <div class="alert alert-info py-2 px-3 small mb-0 mt-3">
                <strong>Best results &mdash; in the Watabou Caves generator, set:</strong>
                <ul class="mb-2 ps-3">
                    <li><strong>Grid:</strong> Hidden</li>
                    <li><strong>Display &rarr; Title:</strong> Off</li>
                    <li><strong>Style &rarr; Preset:</strong> Moonlight</li>
                </ul>
                Then export as <strong>SVG</strong> (vector, not PNG) and upload the <code>.svg</code> here.
                The app overlays its own grid for revealing and legends.
            </div>
            @if (_pendingSvg is not null)
            {
                <div class="small text-success mt-2">Map file loaded &mdash; ready to upload.</div>
            }
        </div>
    </div>
}

@if (!_showUpload)
{
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control qp-input" placeholder="Search by name…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select qp-input" @bind="_mapFilter">
                <option value="">All world maps</option>
                @foreach (var name in _mapOptions)
                {
                    <option value="@name">@name</option>
                }
                <option value="@NoneFilter">— Unassigned —</option>
            </select>
        </div>
    </div>
}

@if (_showUpload)
{
    @* Upload mode: only the upload card above is shown. *@
}
else if (!Filtered.Any())
{
    <p class="text-muted">
        @(_caves.Count == 0
            ? (_isGm ? "No caves yet. Use + Upload above." : "No caves yet. Ask your Gamemaster to add one.")
            : "No matches for your search.")
    </p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:8rem">Locations</th>
                <th>World map</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Filtered)
            {
                @if (_editId == c.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="_editName" placeholder="Cave name" /></td>
                        <td>@c.Locations.Count</td>
                        <td class="@(MapFor(c) is null ? "text-muted" : null)">@(MapFor(c) ?? "—")</td>
                        <td><input class="form-control form-control-sm" @bind="_editDescription" placeholder="Description (optional)" /></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEditAsync(c)">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _editId = null">Cancel</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@c.Name</td>
                        <td>@c.Locations.Count</td>
                        <td class="@(MapFor(c) is null ? "text-muted" : null)">@(MapFor(c) ?? "Unassigned")</td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(c.Description) ? "—" : c.Description)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary me-1" href="/campaign/caves/@c.Id">Open</a>
                            @if (_isGm)
                            {
                                @if (_deleteId == c.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteAsync(c)">Delete?</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _deleteId = null">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(c)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = c.Id">Delete</button>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private const long MaxBytes = 8 * 1024 * 1024;

    private List<CaveMap> _caves = [];
    private Dictionary<int, List<string>> _caveMaps = [];
    private List<string> _mapOptions = [];
    private bool _isGm;
    private string _search = "";
    private bool _showUpload;

    private const string NoneFilter = "::none::";
    private string _mapFilter = "";

    private IEnumerable<CaveMap> Filtered =>
        _caves.Where(c =>
            (string.IsNullOrWhiteSpace(_search)
                || (c.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                || (c.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
            && MatchesMap(c));

    private bool MatchesMap(CaveMap c)
    {
        if (string.IsNullOrEmpty(_mapFilter)) return true;
        var has = _caveMaps.TryGetValue(c.Id, out var names) && names.Count > 0;
        return _mapFilter == NoneFilter ? !has : has && names!.Contains(_mapFilter);
    }
    private string? _currentUserId;
    private string _uploadName = "";
    private string? _pendingSvg;
    private int? _deleteId;
    private int? _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string? _message;
    private bool _isError;

    private bool _canUpload => !string.IsNullOrWhiteSpace(_uploadName) && _pendingSvg is not null;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isGm = auth.User.IsInRole(Roles.Gamemaster);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _caves = await Db.CaveMaps
            .Include(c => c.Locations)
            .OrderBy(c => c.Name)
            .ToListAsync();

        // Which world map(s) link to each cave, via their points of interest.
        var links = await Db.WorldLocations
            .Where(l => l.LinkedCaveId != null)
            .Select(l => new { CaveId = l.LinkedCaveId!.Value, MapName = l.WorldMap!.Name })
            .ToListAsync();
        _caveMaps = links
            .GroupBy(x => x.CaveId)
            .ToDictionary(g => g.Key, g => g.Select(x => x.MapName).Distinct().OrderBy(n => n).ToList());
        _mapOptions = _caveMaps.Values.SelectMany(v => v).Distinct().OrderBy(n => n).ToList();
    }

    private string? MapFor(CaveMap c) =>
        _caveMaps.TryGetValue(c.Id, out var n) && n.Count > 0 ? string.Join(", ", n) : null;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingSvg = null;
        _message = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(MaxBytes));
            var svg = await reader.ReadToEndAsync();
            if (!Maps.IsValid(svg, out var error))
            {
                SetMessage(error ?? "Unrecognized map file.", error: true);
                return;
            }
            _pendingSvg = svg;
            if (string.IsNullOrWhiteSpace(_uploadName))
                _uploadName = Path.GetFileNameWithoutExtension(e.File.Name);
        }
        catch (IOException)
        {
            SetMessage("That file is too large (max 8 MB).", error: true);
        }
    }

    private async Task UploadAsync()
    {
        if (!_isGm || !_canUpload) return;

        var cave = new CaveMap
        {
            Name = _uploadName.Trim(),
            RawSvg = _pendingSvg!,
            CreatedByUserId = _currentUserId,
        };
        Db.CaveMaps.Add(cave);
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/campaign/caves/{cave.Id}");
    }

    private void BeginEdit(CaveMap cave)
    {
        _editId = cave.Id;
        _editName = cave.Name;
        _editDescription = cave.Description ?? "";
        _deleteId = null;
    }

    private async Task SaveEditAsync(CaveMap cave)
    {
        if (!_isGm || string.IsNullOrWhiteSpace(_editName)) return;
        cave.Name = _editName.Trim();
        cave.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
        await Db.SaveChangesAsync();
        _editId = null;
        SetMessage($"Renamed to {cave.Name}.");
    }

    private async Task DeleteAsync(CaveMap cave)
    {
        if (!_isGm) return;
        Db.CaveMaps.Remove(cave);
        await Db.SaveChangesAsync();
        _deleteId = null;
        SetMessage($"Deleted {cave.Name}.");
        await LoadAsync();
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }
}
