@page "/campaign/dungeons"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using RolemasterCharacterCreation.Data
@inject AppDbContext Db
@inject DungeonMapService Maps
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>Dungeons</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Dungeons</h2>
    @if (_isGm)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" @onclick="() => _showUpload = !_showUpload">
                @(_showUpload ? "Close" : "+ Upload")
            </button>
            <a class="btn btn-outline-secondary btn-sm" href="/campaign/dungeon-categories">Legend</a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_isGm && _showUpload)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a new dungeon</h5>
            <p class="text-muted small mb-3">
                Upload a <a href="https://watabou.itch.io/one-page-dungeon" target="_blank" rel="noopener">Watabou
                One-Page Dungeon</a> export (<code>.json</code>). It will be drawn as an interactive map
                you can color-code and reveal room by room.
            </p>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Dungeon name</label>
                    <input class="form-control" @bind="_uploadName" placeholder="e.g. The Sunken Crypt" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Map file (.json)</label>
                    <InputFile class="form-control" accept=".json,application/json" OnChange="OnFileSelected" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" disabled="@(!_canUpload)" @onclick="UploadAsync">
                        Upload Dungeon
                    </button>
                </div>
            </div>
            <div class="alert alert-info py-2 px-3 small mb-0 mt-3">
                <strong>Best results &mdash; in <a href="https://watabou.itch.io/one-page-dungeon" target="_blank" rel="noopener">One-Page Dungeon</a>, set:</strong>
                <ul class="mb-2 ps-3">
                    <li><strong>Layers &rarr; Title &amp; Story:</strong> Off</li>
                    <li><strong>Style &rarr; Preset:</strong> Modern</li>
                </ul>
                Then export the <strong>JSON</strong> (the dungeon data, not the PNG/print image) and upload it here.
                The app re-draws rooms and doors and imports the generator's <strong>notes as legends</strong>,
                so add your room notes before exporting.
            </div>
            @if (_pendingJson is not null)
            {
                <div class="small text-success mt-2">Map file loaded &mdash; ready to upload.</div>
            }
        </div>
    </div>
}

@if (!_showUpload)
{
    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control qp-input" placeholder="Search by name…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select qp-input" @bind="_mapFilter">
                <option value="">All world maps</option>
                @foreach (var name in _mapOptions)
                {
                    <option value="@name">@name</option>
                }
                <option value="@NoneFilter">— Unassigned —</option>
            </select>
        </div>
    </div>
}

@if (_showUpload)
{
    @* Upload mode: only the upload card above is shown. *@
}
else if (!Filtered.Any())
{
    <p class="text-muted">
        @(_dungeons.Count == 0
            ? (_isGm ? "No dungeons yet. Use + Upload above." : "No dungeons yet. Ask your Gamemaster to add one.")
            : "No matches for your search.")
    </p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:8rem">Locations</th>
                <th>World map</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in Filtered)
            {
                @if (_editId == d.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="_editName" placeholder="Dungeon name" /></td>
                        <td>@d.Locations.Count</td>
                        <td class="@(MapFor(d) is null ? "text-muted" : null)">@(MapFor(d) ?? "—")</td>
                        <td><input class="form-control form-control-sm" @bind="_editDescription" placeholder="Description (optional)" /></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEditAsync(d)">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _editId = null">Cancel</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@d.Name</td>
                        <td>@d.Locations.Count</td>
                        <td class="@(MapFor(d) is null ? "text-muted" : null)">@(MapFor(d) ?? "Unassigned")</td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(d.Description) ? "—" : d.Description)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary me-1" href="/campaign/dungeons/@d.Id">Open</a>
                            @if (_isGm)
                            {
                                @if (_deleteId == d.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteAsync(d)">Delete?</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _deleteId = null">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(d)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = d.Id">Delete</button>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private const long MaxBytes = 5 * 1024 * 1024;

    private List<DungeonMap> _dungeons = [];
    private Dictionary<int, List<string>> _dungeonMaps = [];
    private List<string> _mapOptions = [];
    private bool _isGm;
    private string _search = "";
    private bool _showUpload;

    private const string NoneFilter = "::none::";
    private string _mapFilter = "";

    private IEnumerable<DungeonMap> Filtered =>
        _dungeons.Where(d =>
            (string.IsNullOrWhiteSpace(_search)
                || (d.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false)
                || (d.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false))
            && MatchesMap(d));

    private bool MatchesMap(DungeonMap d)
    {
        if (string.IsNullOrEmpty(_mapFilter)) return true;
        var has = _dungeonMaps.TryGetValue(d.Id, out var names) && names.Count > 0;
        return _mapFilter == NoneFilter ? !has : has && names!.Contains(_mapFilter);
    }
    private string? _currentUserId;
    private string _uploadName = "";
    private string? _pendingJson;
    private int? _deleteId;
    private int? _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string? _message;
    private bool _isError;

    private bool _canUpload => !string.IsNullOrWhiteSpace(_uploadName) && _pendingJson is not null;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isGm = auth.User.IsInRole(Roles.Gamemaster);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _dungeons = await Db.DungeonMaps
            .Include(d => d.Locations)
            .OrderBy(d => d.Name)
            .ToListAsync();

        // Which world map(s) link to each dungeon, via their points of interest.
        var links = await Db.WorldLocations
            .Where(l => l.LinkedDungeonId != null)
            .Select(l => new { DungeonId = l.LinkedDungeonId!.Value, MapName = l.WorldMap!.Name })
            .ToListAsync();
        _dungeonMaps = links
            .GroupBy(x => x.DungeonId)
            .ToDictionary(g => g.Key, g => g.Select(x => x.MapName).Distinct().OrderBy(n => n).ToList());
        _mapOptions = _dungeonMaps.Values.SelectMany(v => v).Distinct().OrderBy(n => n).ToList();
    }

    private string? MapFor(DungeonMap d) =>
        _dungeonMaps.TryGetValue(d.Id, out var n) && n.Count > 0 ? string.Join(", ", n) : null;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingJson = null;
        _message = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(MaxBytes));
            var json = await reader.ReadToEndAsync();
            if (!Maps.IsValid(json, out var error))
            {
                SetMessage(error ?? "Unrecognized map file.", error: true);
                return;
            }
            _pendingJson = json;
            if (string.IsNullOrWhiteSpace(_uploadName))
                _uploadName = Path.GetFileNameWithoutExtension(e.File.Name);
        }
        catch (IOException)
        {
            SetMessage("That file is too large (max 5 MB).", error: true);
        }
    }

    private async Task UploadAsync()
    {
        if (!_isGm || !_canUpload) return;

        var dungeon = new DungeonMap
        {
            Name = _uploadName.Trim(),
            RawJson = _pendingJson!,
            CreatedByUserId = _currentUserId,
        };
        Db.DungeonMaps.Add(dungeon);
        await Db.SaveChangesAsync();
        Nav.NavigateTo($"/campaign/dungeons/{dungeon.Id}");
    }

    private void BeginEdit(DungeonMap dungeon)
    {
        _editId = dungeon.Id;
        _editName = dungeon.Name;
        _editDescription = dungeon.Description ?? "";
        _deleteId = null;
    }

    private async Task SaveEditAsync(DungeonMap dungeon)
    {
        if (!_isGm || string.IsNullOrWhiteSpace(_editName)) return;
        dungeon.Name = _editName.Trim();
        dungeon.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
        await Db.SaveChangesAsync();
        _editId = null;
        SetMessage($"Renamed to {dungeon.Name}.");
    }

    private async Task DeleteAsync(DungeonMap dungeon)
    {
        if (!_isGm) return;
        Db.DungeonMaps.Remove(dungeon);
        await Db.SaveChangesAsync();
        _deleteId = null;
        SetMessage($"Deleted {dungeon.Name}.");
        await LoadAsync();
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }
}
