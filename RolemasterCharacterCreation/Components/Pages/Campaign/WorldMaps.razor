@page "/campaign/world-maps"
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@using RolemasterCharacterCreation.Data
@inject AppDbContext Db
@inject WorldMapService Maps
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>World Maps</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">World Maps</h2>
    @if (_isGm)
    {
        <div class="d-flex gap-2">
            <button class="btn btn-success btn-sm" @onclick="() => _showUpload = !_showUpload">
                @(_showUpload ? "Close" : "+ Upload")
            </button>
            <a class="btn btn-outline-secondary btn-sm" href="/campaign/world-categories">Legend</a>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_isGm && _showUpload)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Upload a new world map</h5>
            <p class="text-muted small mb-3">
                Upload a Watabou <em>Perilous Shores</em> region export (<code>.json</code>). Its
                generated cities, towns, villages and sites will be added as points of interest you can annotate.
            </p>
            <div class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Map name</label>
                    <input class="form-control" @bind="_uploadName" placeholder="e.g. Azurecrest Isles" />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Map file (.json)</label>
                    <InputFile class="form-control" accept=".json,application/json" OnChange="OnFileSelected" />
                </div>
                <div class="col-md-3">
                    <button class="btn btn-success" disabled="@(!_canUpload)" @onclick="UploadAsync">
                        Upload Map
                    </button>
                </div>
            </div>
            <div class="alert alert-info py-2 px-3 small mb-0 mt-3">
                <strong>Best results &mdash; export from <a href="https://watabou.github.io/perilous-shores/" target="_blank" rel="noopener">Perilous Shores</a> with these settings:</strong>
                <ul class="mb-2 ps-3">
                    <li><strong>Region size:</strong> 2000 &times; 2000</li>
                    <li><strong>Style preset:</strong> Soft</li>
                    <li><strong>Details &rarr; Town:</strong> Hidden &nbsp;&middot;&nbsp; <strong>Roads:</strong> Off</li>
                    <li><strong>Danger:</strong> Off</li>
                    <li><strong>Grid:</strong> Hidden</li>
                    <li><strong>Labels:</strong> Hidden</li>
                </ul>
                Then use <strong>Export &rarr; JSON</strong> (the map data, not an image) and upload the
                <code>.json</code> here. Hidden towns still import as points of interest.
            </div>
            @if (_pendingJson is not null)
            {
                <div class="small text-success mt-2">Map file loaded &mdash; ready to upload.</div>
            }
        </div>
    </div>
}

@if (!_showUpload)
{
    <div class="mb-3">
        <input class="form-control qp-input" placeholder="Search by name…"
               @bind="_search" @bind:event="oninput" />
    </div>
}

@if (_showUpload)
{
    @* Upload mode: only the upload card above is shown. *@
}
else if (!Filtered.Any())
{
    <p class="text-muted">
        @(_maps.Count == 0
            ? (_isGm ? "No world maps yet. Use + Upload above." : "No world maps yet. Ask your Gamemaster to add one.")
            : "No matches for your search.")
    </p>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Name</th>
                <th style="width:11rem">Points of interest</th>
                <th>Description</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var m in Filtered)
            {
                @if (_editId == m.Id)
                {
                    <tr>
                        <td><input class="form-control form-control-sm" @bind="_editName" placeholder="Map name" /></td>
                        <td>@m.Locations.Count</td>
                        <td><input class="form-control form-control-sm" @bind="_editDescription" placeholder="Description (optional)" /></td>
                        <td class="text-end text-nowrap">
                            <button class="btn btn-sm btn-success me-1" @onclick="() => SaveEditAsync(m)">Save</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _editId = null">Cancel</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@m.Name</td>
                        <td>@m.Locations.Count</td>
                        <td class="text-muted">@(string.IsNullOrWhiteSpace(m.Description) ? "—" : m.Description)</td>
                        <td class="text-end text-nowrap">
                            <a class="btn btn-sm btn-outline-primary me-1" href="/campaign/world-maps/@m.Id">Open</a>
                            @if (_isGm)
                            {
                                @if (_deleteId == m.Id)
                                {
                                    <button class="btn btn-sm btn-danger me-1" @onclick="() => DeleteAsync(m)">Delete?</button>
                                    <button class="btn btn-sm btn-secondary" @onclick="() => _deleteId = null">No</button>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => BeginEdit(m)">Rename</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = m.Id">Delete</button>
                                }
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    private const long MaxBytes = 8 * 1024 * 1024;

    private List<WorldMap> _maps = [];
    private bool _isGm;
    private string _search = "";
    private bool _showUpload;

    private IEnumerable<WorldMap> Filtered =>
        string.IsNullOrWhiteSpace(_search)
            ? _maps
            : _maps.Where(m =>
                (m.Name?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
                (m.Description?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));
    private string? _currentUserId;
    private string _uploadName = "";
    private string? _pendingJson;
    private int? _deleteId;
    private int? _editId;
    private string _editName = "";
    private string _editDescription = "";
    private string? _message;
    private bool _isError;

    private bool _canUpload => !string.IsNullOrWhiteSpace(_uploadName) && _pendingJson is not null;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _currentUserId = auth.User.FindFirstValue(ClaimTypes.NameIdentifier);
        _isGm = auth.User.IsInRole(Roles.Gamemaster);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _maps = await Db.WorldMaps
            .Include(m => m.Locations)
            .OrderBy(m => m.Name)
            .ToListAsync();
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        _pendingJson = null;
        _message = null;
        try
        {
            using var reader = new StreamReader(e.File.OpenReadStream(MaxBytes));
            var json = await reader.ReadToEndAsync();
            if (!Maps.IsValid(json, out var error))
            {
                SetMessage(error ?? "Unrecognized map file.", error: true);
                return;
            }
            _pendingJson = json;
            if (string.IsNullOrWhiteSpace(_uploadName))
                _uploadName = Path.GetFileNameWithoutExtension(e.File.Name);
        }
        catch (IOException)
        {
            SetMessage("That file is too large (max 8 MB).", error: true);
        }
    }

    private async Task UploadAsync()
    {
        if (!_isGm || !_canUpload) return;

        var map = new WorldMap
        {
            Name = _uploadName.Trim(),
            RawJson = _pendingJson!,
            CreatedByUserId = _currentUserId,
        };
        Db.WorldMaps.Add(map);
        await Db.SaveChangesAsync();

        await ImportPoisAsync(map);

        Nav.NavigateTo($"/campaign/world-maps/{map.Id}");
    }

    // Seeds the generated settlements/sites as editable POIs, matched to the world palette.
    private async Task ImportPoisAsync(WorldMap map)
    {
        var pois = Maps.ExtractPois(map.RawJson);
        if (pois.Count == 0) return;

        var categories = await Db.WorldCategories.ToListAsync();
        var byName = categories.ToDictionary(c => c.Name, StringComparer.OrdinalIgnoreCase);
        var fallback = categories.OrderBy(c => c.SortOrder).FirstOrDefault();
        if (fallback is null) return;

        var seen = new HashSet<(int, int)>();
        foreach (var p in pois)
        {
            if (!seen.Add((p.Q, p.R))) continue; // one POI per hex
            var category = byName.TryGetValue(p.Category, out var c) ? c : fallback;
            Db.WorldLocations.Add(new WorldLocation
            {
                WorldMapId = map.Id,
                HexQ = p.Q,
                HexR = p.R,
                WorldCategoryId = category.Id,
                Label = p.Name,
                Notes = p.Info,
            });
        }
        await Db.SaveChangesAsync();
    }

    private void BeginEdit(WorldMap map)
    {
        _editId = map.Id;
        _editName = map.Name;
        _editDescription = map.Description ?? "";
        _deleteId = null;
    }

    private async Task SaveEditAsync(WorldMap map)
    {
        if (!_isGm || string.IsNullOrWhiteSpace(_editName)) return;
        map.Name = _editName.Trim();
        map.Description = string.IsNullOrWhiteSpace(_editDescription) ? null : _editDescription.Trim();
        await Db.SaveChangesAsync();
        _editId = null;
        SetMessage($"Renamed to {map.Name}.");
    }

    private async Task DeleteAsync(WorldMap map)
    {
        if (!_isGm) return;
        Db.WorldMaps.Remove(map);
        await Db.SaveChangesAsync();
        _deleteId = null;
        SetMessage($"Deleted {map.Name}.");
        await LoadAsync();
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }
}
