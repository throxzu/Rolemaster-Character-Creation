@page "/gm/players"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Gamemaster)]
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using RolemasterCharacterCreation.Data
@using RolemasterCharacterCreation.Identity
@using RolemasterCharacterCreation.Services
@inject UserManager<ApplicationUser> UserManager
@inject AppDbContext Db
@inject ISmsSender Sms
@inject ILogger<Players> Logger

<PageTitle>Players</PageTitle>

<h2>Players</h2>

@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success") alert-dismissible">
        @_message
        <button type="button" class="btn-close" @onclick="() => _message = null"></button>
    </div>
}

@if (_lastInvite is not null)
{
    <div class="alert alert-info alert-dismissible">
        <div><strong>@_lastInvite.Name</strong> (@_lastInvite.Phone) was added.</div>
        <div>First-time password: <code>@_lastInvite.Password</code></div>
        <div>SMS: @_lastInvite.SmsStatus</div>
        <button type="button" class="btn-close" @onclick="() => _lastInvite = null"></button>
    </div>
}

<button class="btn btn-primary mb-3" @onclick="() => _showCreate = !_showCreate">
    @(_showCreate ? "Cancel" : "+ New Player")
</button>

@if (_showCreate)
{
    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Invite Player</h5>
            <EditForm Model="_createModel" OnValidSubmit="CreatePlayerAsync">
                <DataAnnotationsValidator />
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Full name</label>
                        <InputText @bind-Value="_createModel.FullName" class="form-control" />
                        <ValidationMessage For="() => _createModel.FullName" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Country</label>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary dropdown-toggle w-100 d-flex align-items-center gap-2"
                                    type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="@_country.ImagePath" alt="@_country.Name" width="22" height="16"
                                     style="border:1px solid rgba(0,0,0,.15);" />
                                <span>@_country.Dial</span>
                            </button>
                            <ul class="dropdown-menu w-100">
                                @foreach (var c in CountryDialCodes.All)
                                {
                                    <li>
                                        <button type="button" class="dropdown-item d-flex align-items-center gap-2"
                                                @onclick="() => SelectCountry(c)">
                                            <img src="@c.ImagePath" alt="@c.Name" width="22" height="16"
                                                 style="border:1px solid rgba(0,0,0,.15);" />
                                            <span>@c.Name (@c.Dial)</span>
                                        </button>
                                    </li>
                                }
                            </ul>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Phone number</label>
                        <InputText @bind-Value="_createModel.LocalNumber" class="form-control" placeholder="12345678" />
                        <ValidationMessage For="() => _createModel.LocalNumber" />
                    </div>
                </div>
                <button type="submit" class="btn btn-success mt-3" disabled="@_sending">
                    @(_sending ? "Sending…" : "Create & send invite")
                </button>
            </EditForm>
        </div>
    </div>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>Full Name</th>
            <th>Phone</th>
            <th>Status</th>
            <th>Characters</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var player in _players)
        {
            <tr>
                <td>@player.DisplayName</td>
                <td>@player.PhoneNumber</td>
                <td>
                    @if (string.IsNullOrEmpty(player.Email))
                    {
                        <span class="badge bg-warning text-dark">Pending first login</span>
                    }
                    else
                    {
                        <span class="text-muted">@player.Email</span>
                    }
                </td>
                <td>@player.Characters.Count</td>
                <td class="text-end">
                    @if (_resetId == player.Id)
                    {
                        <div class="d-inline-flex gap-2 align-items-center">
                            <InputText @bind-Value="_newPassword" placeholder="New password" class="form-control form-control-sm" style="width:180px" />
                            <button class="btn btn-sm btn-warning" @onclick="() => ResetPasswordAsync(player)">Confirm Reset</button>
                            <button class="btn btn-sm btn-secondary" @onclick="() => _resetId = null">Cancel</button>
                        </div>
                    }
                    else if (_deleteId == player.Id)
                    {
                        <span class="me-2">Delete <strong>@player.DisplayName</strong>?</span>
                        <button class="btn btn-sm btn-danger" @onclick="() => DeletePlayerAsync(player)">Yes, delete</button>
                        <button class="btn btn-sm btn-secondary ms-1" @onclick="() => _deleteId = null">Cancel</button>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-secondary me-1" @onclick="() => { _resetId = player.Id; _newPassword = string.Empty; }">Reset Password</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => _deleteId = player.Id">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!_players.Any())
{
    <p class="text-muted">No players yet. Create one above.</p>
}

@code {
    private List<ApplicationUser> _players = [];
    private bool _showCreate;
    private bool _sending;
    private string? _message;
    private bool _isError;
    private string? _deleteId;
    private string? _resetId;
    private string _newPassword = string.Empty;
    private CreateModel _createModel = new();
    private CountryDialCode _country = CountryDialCodes.Default;
    private InviteInfo? _lastInvite;

    private void SelectCountry(CountryDialCode c)
    {
        _country = c;
        _createModel.Dial = c.Dial;
    }

    protected override async Task OnInitializedAsync() => await LoadPlayersAsync();

    private async Task LoadPlayersAsync()
    {
        var playerIds = (await UserManager.GetUsersInRoleAsync(Roles.Player))
            .Select(u => u.Id)
            .ToHashSet();

        _players = await Db.Users
            .Include(u => u.Characters)
            .Where(u => playerIds.Contains(u.Id))
            .OrderBy(u => u.DisplayName)
            .ToListAsync();
    }

    private async Task CreatePlayerAsync()
    {
        // Build the E.164 number: chosen dial code + local digits (drop a leading trunk 0).
        var localDigits = new string(_createModel.LocalNumber.Where(char.IsDigit).ToArray()).TrimStart('0');
        if (localDigits.Length < 4)
        {
            SetMessage("Enter a valid phone number.", error: true);
            return;
        }
        var e164 = _createModel.Dial + localDigits;

        var password = TempPassword.Generate();
        var user = new ApplicationUser
        {
            UserName = e164,
            PhoneNumber = e164,
            DisplayName = _createModel.FullName.Trim(),
        };

        _sending = true;
        try
        {
            var result = await UserManager.CreateAsync(user, password);
            if (!result.Succeeded)
            {
                SetMessage(string.Join("; ", result.Errors.Select(e => e.Description)), error: true);
                return;
            }

            await UserManager.AddToRoleAsync(user, Roles.Player);
            await UserManager.AddClaimAsync(user, new Claim(InviteClaims.Type, InviteClaims.Required));

            var settings = await Db.CampaignSettings.FirstOrDefaultAsync();
            var campaignName = settings?.Name ?? "the campaign";
            var loginUrl = settings?.LoginUrl ?? "https://rolemaster.isager.dk";
            var message = BuildInviteMessage(settings?.InviteSmsTemplate, campaignName, loginUrl, password);

            var sms = await Sms.SendAsync(e164, message);
            var smsStatus = sms.Success
                ? $"sent{(sms.QuotaRemaining is { } q ? $" (quota left: {q})" : "")}."
                : $"NOT sent — {sms.Error} Relay the password manually.";

            _lastInvite = new InviteInfo(user.DisplayName!, e164, password, smsStatus);
            _message = null;
            _createModel = new();
            _country = CountryDialCodes.Default;
            _showCreate = false;
            await LoadPlayersAsync();
        }
        finally
        {
            _sending = false;
        }
    }

    private static string BuildInviteMessage(string? template, string campaign, string url, string password)
    {
        if (!string.IsNullOrWhiteSpace(template))
        {
            return template
                .Replace("{campaign}", campaign)
                .Replace("{url}", url)
                .Replace("{password}", password);
        }

        // URLs are stripped from all outgoing SMS, so the invite points to the site by name only.
        return $"You are invited to join the campaign {campaign}. " +
               $"Log in with your phone number. " +
               $"Your first-time password is: {password}";
    }

    private async Task DeletePlayerAsync(ApplicationUser player)
    {
        var result = await UserManager.DeleteAsync(player);
        _deleteId = null;
        SetMessage(result.Succeeded ? $"Player {player.DisplayName} deleted." : "Delete failed.", !result.Succeeded);
        if (result.Succeeded) await LoadPlayersAsync();
    }

    private async Task ResetPasswordAsync(ApplicationUser player)
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            SetMessage("Password cannot be empty.", error: true);
            return;
        }

        var token = await UserManager.GeneratePasswordResetTokenAsync(player);
        var result = await UserManager.ResetPasswordAsync(player, token, _newPassword);
        _resetId = null;
        SetMessage(result.Succeeded ? $"Password reset for {player.DisplayName}." : "Reset failed.", !result.Succeeded);
    }

    private void SetMessage(string msg, bool error = false)
    {
        _message = msg;
        _isError = error;
    }

    private sealed record InviteInfo(string Name, string Phone, string Password, string SmsStatus);

    private sealed class CreateModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string FullName { get; set; } = "";

        [System.ComponentModel.DataAnnotations.Required]
        public string Dial { get; set; } = CountryDialCodes.Default.Dial;

        [System.ComponentModel.DataAnnotations.Required]
        public string LocalNumber { get; set; } = "";
    }
}
