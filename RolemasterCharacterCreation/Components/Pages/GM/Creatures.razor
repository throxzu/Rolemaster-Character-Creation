@page "/gm/creatures"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Gamemaster)]
@using Microsoft.EntityFrameworkCore
@using RolemasterCharacterCreation.Data
@using RolemasterCharacterCreation.Services
@inject CreatureService CreatureSvc
@inject AppDbContext Db

<PageTitle>Creatures</PageTitle>

<div class="container-fluid mt-3">
    <h2 class="mb-3">Creature Lookup</h2>

    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control qp-input" placeholder="Search by name…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select qp-input" @bind="_groupFilter">
                <option value="">All categories</option>
                @foreach (var g in CreatureSvc.CategoryGroups)
                {
                    <option value="@g">@g</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-center text-muted small">
            @Filtered.Count() creatures
        </div>
    </div>

    <div class="row g-3">
        <!-- ── Creature list ──────────────────────────── -->
        <div class="col-md-4 col-lg-3">
            <div class="creature-list qp-card p-0">
                @foreach (var c in Filtered)
                {
                    <button class="creature-list-item @(_selected == c ? "active" : "")"
                            @onclick="() => _selected = c">
                        <span class="creature-list-name">@c.Name</span>
                        <span class="creature-list-cat text-muted small">@c.Category</span>
                    </button>
                }
            </div>
        </div>

        <!-- ── Stat block detail ─────────────────────── -->
        <div class="col-md-8 col-lg-9">
            @if (_selected is { } cr)
            {
                <div class="qp-card p-4">
                    <h3 class="creature-name mb-3">@cr.Name.ToUpperInvariant()</h3>

                    <table class="table table-sm table-bordered stat-info mb-3">
                        <tbody>
                            @StatInfoRow("Category",  cr.Category)
                            @StatInfoRow("Archetype", cr.Archetype)
                            @StatInfoRow("Size",      cr.Size)
                            @StatInfoRow("Armor",     cr.Armor)
                            @if (!string.IsNullOrWhiteSpace(cr.Heal))
                            { @StatInfoRow("Heal", cr.Heal) }
                            @if (!string.IsNullOrWhiteSpace(cr.Treasure) && cr.Treasure != "-")
                            { @StatInfoRow("Treasure", cr.Treasure) }
                            @StatInfoRow("Realm", cr.Realm)
                            @if (!string.IsNullOrWhiteSpace(cr.Misc))
                            { @StatInfoRow("Misc", cr.Misc) }
                        </tbody>
                    </table>

                    <!-- Stat bonuses -->
                    <div class="mb-3">
                        <div class="section-label mb-1">Stat Bonuses</div>
                        <table class="table table-sm table-bordered stat-bonus-table mb-0">
                            <thead>
                                <tr>
                                    @foreach (var lbl in CreatureEntry.StatLabels)
                                    {
                                        <th class="text-center">@lbl</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    @for (int i = 0; i < cr.StatBonuses.Length; i++)
                                    {
                                        var v   = cr.StatBonuses[i];
                                        var cls = v > 0 ? "stat-pos" : v < 0 ? "stat-neg" : "stat-zero";
                                        <td class="text-center @cls">@(v > 0 ? "+" : "")@v</td>
                                    }
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <!-- Spells -->
                    @{ var spellInfo = CreatureSpells.Parse(cr.Spells); }
                    @if (spellInfo.HasContent)
                    {
                        <div class="mb-3">
                            <div class="section-label mb-1">Spells</div>
                            @if (!string.IsNullOrWhiteSpace(spellInfo.Note))
                            {
                                <p class="creature-spell-note mb-2">@spellInfo.Note</p>
                            }
                            @foreach (var g in spellInfo.Groups)
                            {
                                <div class="spell-group">
                                    @if (!string.IsNullOrWhiteSpace(g.Label))
                                    {
                                        <div class="spell-group-label">@g.Label</div>
                                    }
                                    <div class="spell-chips">
                                        @foreach (var s in g.Lists)
                                        {
                                            <span class="spell-chip">
                                                @if (!string.IsNullOrEmpty(s.Range))
                                                {
                                                    <span class="spell-range">@s.Range</span>
                                                }
                                                @{ var href = SpellListLink(s.Name); }
                                                @if (href is not null)
                                                {
                                                    <a class="spell-link" href="@href" target="_blank">@s.Name</a>
                                                }
                                                else
                                                {
                                                    <span class="spell-name">@s.Name</span>
                                                }
                                                @if (!string.IsNullOrWhiteSpace(s.Meta))
                                                {
                                                    <span class="spell-meta">@s.Meta</span>
                                                }
                                            </span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    }

                    <!-- Talents / Flaws -->
                    @if (!string.IsNullOrWhiteSpace(cr.TalentsFlaws))
                    {
                        <div class="mb-3">
                            <div class="section-label mb-1">Talents / Flaws</div>
                            <div class="talents-text">
                                @foreach (var t in cr.TalentsFlaws.Split(';',
                                    StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <span class="talent-chip">@t</span>
                                }
                            </div>
                        </div>
                    }

                    <!-- Description -->
                    @{ var desc = DescriptionFor(cr); }
                    @if (!string.IsNullOrWhiteSpace(desc))
                    {
                        <div>
                            <div class="section-label mb-1">Description</div>
                            <p class="creature-desc">@desc</p>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="qp-card p-4 text-muted text-center">
                    Select a creature from the list.
                </div>
            }
        </div>
    </div>
</div>

<style>
    .creature-list {
        height: calc(100vh - 180px);
        overflow-y: auto;
        display: flex;
        flex-direction: column;
    }
    .creature-list-item {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        padding: 8px 14px;
        border: none;
        border-bottom: 1px solid var(--qp-border-panel);
        background: transparent;
        color: var(--qp-text-primary);
        cursor: pointer;
        text-align: left;
        transition: background 0.12s;
    }
    .creature-list-item:hover  { background: var(--qp-bg-panel-alt); }
    .creature-list-item.active { background: var(--qp-blue); color: #fff; }
    .creature-list-item.active .text-muted { color: rgba(255,255,255,.7) !important; }
    .creature-list-name  { font-weight: 500; }
    .creature-list-cat   { font-size: .78rem; margin-top: 1px; }
    .creature-name       { color: var(--qp-teal); font-weight: 700; letter-spacing: .04em; }
    .section-label       { font-size: .75rem; font-weight: 600; text-transform: uppercase;
                           letter-spacing: .08em; color: var(--qp-text-label); }
    .stat-info           { margin-bottom: 0; }
    .stat-info td        { border-color: var(--qp-border-panel) !important; padding: 4px 10px; }
    .stat-info td:first-child {
        color: var(--qp-text-label); font-size: .8rem; font-weight: 600;
        text-transform: uppercase; letter-spacing: .05em; width: 110px;
        background: var(--qp-bg-panel);
    }
    .stat-bonus-table    { font-size: .9rem; }
    .stat-bonus-table th { color: var(--qp-text-label); font-weight: 600;
                           background: var(--qp-bg-panel); border-color: var(--qp-border-panel) !important; }
    .stat-bonus-table td { background: var(--qp-bg-panel-alt); border-color: var(--qp-border-panel) !important;
                           font-weight: 600; }
    .stat-pos   { color: var(--qp-green); }
    .stat-neg   { color: var(--qp-red); }
    .stat-zero  { color: var(--qp-text-muted); }
    .talents-text { display: flex; flex-wrap: wrap; gap: 6px; }
    .talent-chip  { background: var(--qp-bg-panel); border: 1px solid var(--qp-border-panel);
                    border-radius: 6px; padding: 3px 8px; font-size: .82rem; color: var(--qp-text-primary); }
    .creature-desc { color: var(--qp-text-primary); line-height: 1.7; }
    .creature-spell-note { color: var(--qp-text-muted); font-size: .85rem; font-style: italic; line-height: 1.5; }
    .spell-group { margin-bottom: 10px; }
    .spell-group-label { font-size: .72rem; font-weight: 600; text-transform: uppercase; letter-spacing: .06em;
                         color: var(--qp-teal); margin-bottom: 4px; }
    .spell-chips { display: flex; flex-wrap: wrap; gap: 6px; }
    .spell-chip  { display: inline-flex; align-items: baseline; gap: 5px;
                   background: var(--qp-bg-panel); border: 1px solid var(--qp-border-panel);
                   border-radius: 6px; padding: 3px 9px; font-size: .85rem; }
    .spell-range { font-size: .72rem; font-weight: 600; color: var(--qp-text-label);
                   background: var(--qp-bg-panel-alt); border-radius: 4px; padding: 0 5px; }
    .spell-link  { color: var(--qp-blue); font-weight: 500; text-decoration: none; }
    .spell-link:hover { text-decoration: underline; }
    .spell-name  { color: var(--qp-text-primary); font-weight: 500; }
    .spell-meta  { color: var(--qp-text-muted); font-size: .75rem; }
</style>

@code {
    // Deep-link target, e.g. /gm/creatures?name=Basilisk (used by the Creature Tables page).
    [SupplyParameterFromQuery(Name = "name")]
    public string? CreatureName { get; set; }

    private string _search      = "";
    private string _groupFilter = "";
    private CreatureEntry? _selected;

    // Curated descriptions seeded from docs/game-data/creature-descriptions.json.
    private Dictionary<string, string> _descriptions = new(StringComparer.OrdinalIgnoreCase);

    // Maps a normalised spell-list name → its canonical name, for deep-linking
    // creature spell lists to the /spells page (list names are globally unique).
    private Dictionary<string, string> _spellListNames = new();

    protected override async Task OnInitializedAsync()
    {
        _descriptions = await Db.CreatureDescriptions
            .AsNoTracking()
            .ToDictionaryAsync(c => c.Name, c => c.Description, StringComparer.OrdinalIgnoreCase);

        var names = await Db.SpellLists.AsNoTracking().Select(l => l.Name).ToListAsync();
        _spellListNames = names
            .GroupBy(NormalizeListName)
            .ToDictionary(g => g.Key, g => g.First());

        // Deep-link: pre-select the requested creature. Try an exact (case-insensitive)
        // match first, then a loose match (ignore spaces/commas/apostrophes) to tolerate
        // OCR naming differences; otherwise drop the term into the search box as a hint.
        if (!string.IsNullOrWhiteSpace(CreatureName))
        {
            var target = NormalizeCreatureName(CreatureName);
            _selected = CreatureSvc.All.FirstOrDefault(c =>
                            c.Name.Equals(CreatureName, StringComparison.OrdinalIgnoreCase))
                     ?? CreatureSvc.All.FirstOrDefault(c =>
                            NormalizeCreatureName(c.Name) == target);
            if (_selected is null) { _search = CreatureName; }
        }
    }

    private static string NormalizeCreatureName(string name) =>
        new string(name.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();

    // Apostrophe styles differ between the creature source (') and the spell data (’).
    private static string NormalizeListName(string name) =>
        name.Replace('’', '\'').Trim().ToLowerInvariant();

    private string? SpellListLink(string name) =>
        _spellListNames.TryGetValue(NormalizeListName(name), out var canonical)
            ? $"/spells?list={Uri.EscapeDataString(canonical)}"
            : null;

    // Prefer the curated DB text; fall back to the parser's extraction if absent.
    private string DescriptionFor(CreatureEntry c) =>
        _descriptions.TryGetValue(c.Name, out var d) ? d : c.Description;

    private IEnumerable<CreatureEntry> Filtered =>
        CreatureSvc.All
            .Where(c => (string.IsNullOrEmpty(_groupFilter) || c.CategoryGroup == _groupFilter)
                     && (string.IsNullOrEmpty(_search)      ||
                         c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)))
            .OrderBy(c => c.Name);

    private static RenderFragment StatInfoRow(string label, string value) => __builder =>
    {
        <tr>
            <td>@label</td>
            <td>@value</td>
        </tr>
    };
}
