@page "/session-notes"
@rendermode InteractiveServer
@attribute [Authorize]
@using RolemasterCharacterCreation.Data
@using RolemasterCharacterCreation.Models
@inject AppDbContext Db

<PageTitle>Session Notes</PageTitle>

<h2 class="mb-3">Session Notes</h2>

<p class="text-muted">A recap of each game session, kept by your GM.</p>

@if (_notes.Count == 0)
{
    <p class="fst-italic text-muted">No session notes have been posted yet.</p>
}
else
{
    @foreach (var n in _notes)
    {
        <div class="card mb-3" style="max-width:820px">
            <div class="card-body">
                <h5 class="card-title mb-0">@n.Title</h5>
                <div class="small text-muted">@n.SessionDate.ToString("dddd, d MMMM yyyy")</div>
                @if (!string.IsNullOrWhiteSpace(n.PublicNotes))
                {
                    <p class="mt-3 mb-0" style="white-space:pre-wrap">@n.PublicNotes</p>
                }
            </div>
        </div>
    }
}

@code {
    private List<SessionNote> _notes = [];

    protected override async Task OnInitializedAsync() =>
        _notes = await Db.SessionNotes
            .OrderByDescending(n => n.SessionDate)
            .ThenByDescending(n => n.Id)
            .ToListAsync();
}
