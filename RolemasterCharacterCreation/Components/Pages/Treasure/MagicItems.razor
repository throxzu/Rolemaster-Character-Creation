@page "/treasure/magic-items"
@rendermode InteractiveServer
@attribute [Authorize(Roles = Roles.Gamemaster)]
@using RolemasterCharacterCreation.Identity
@using RolemasterCharacterCreation.Models
@using RolemasterCharacterCreation.Services
@inject MagicItemService Items

<PageTitle>Magic Items</PageTitle>

<div class="container-fluid mt-3">
    <div class="d-flex flex-wrap align-items-baseline gap-2 mb-3">
        <h2 class="mb-0">Magic Items</h2>
        <span class="mi-gm-tag" title="Gamemaster only">GM only</span>
        <span class="text-muted small">Treasure Law &mdash; Magic Item Compendium</span>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-md-5">
            <input class="form-control form-control-sm" placeholder="Search items…"
                   @bind="_search" @bind:event="oninput" />
        </div>
        <div class="col-md-4">
            <select class="form-select form-select-sm" @bind="_categoryFilter">
                <option value="">All categories</option>
                @foreach (var c in Items.Categories)
                {
                    <option value="@c">@c</option>
                }
            </select>
        </div>
        <div class="col-md-3 d-flex align-items-center text-muted small">
            @Filtered.Count() items
        </div>
    </div>

    <div class="row g-3">
        <!-- ── Left: searchable, grouped list ── -->
        <div class="col-md-4 col-lg-3">
            <div class="mi-list qp-card p-0">
                @foreach (var grp in Filtered.GroupBy(i => i.Category)
                              .OrderBy(g => CategoryRank(g.Key)))
                {
                    <div class="mi-group-header">@grp.Key</div>
                    @foreach (var item in grp.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase))
                    {
                        <div class="mi-list-item @(_selected == item ? "active" : "")"
                             @onclick="() => _selected = item">
                            @item.Name
                            @if (item.Created)
                            {
                                <span class="mi-created-tag" title="AI-generated">Created</span>
                            }
                        </div>
                    }
                }
                @if (!Filtered.Any())
                {
                    <div class="p-3 text-muted">No items match.</div>
                }
            </div>
        </div>

        <!-- ── Right: selected item ── -->
        <div class="col-md-8 col-lg-9">
            @if (_selected is { } it)
            {
                <div class="qp-card p-4">
                    <div class="d-flex flex-wrap align-items-baseline gap-2 mb-2">
                        <h3 class="mi-title mb-0">@it.Name</h3>
                        <span class="mi-cat">@it.Category</span>
                        @if (it.Created)
                        {
                            <span class="mi-created-tag" title="AI-generated">Created</span>
                        }
                    </div>

                    @if (!string.IsNullOrWhiteSpace(it.Level) || !string.IsNullOrWhiteSpace(it.Cost)
                         || !string.IsNullOrWhiteSpace(it.Days))
                    {
                        <div class="mi-stats mb-3">
                            @if (!string.IsNullOrWhiteSpace(it.Level))
                            {
                                <span class="mi-stat"><span class="mi-stat-label">Level</span> @it.Level</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(it.Cost))
                            {
                                <span class="mi-stat"><span class="mi-stat-label">Cost</span> @it.Cost</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(it.Days))
                            {
                                <span class="mi-stat"><span class="mi-stat-label">Days</span> @it.Days</span>
                            }
                        </div>
                    }

                    <p class="mi-desc">@it.Description</p>

                    @if (!string.IsNullOrWhiteSpace(it.Recipe))
                    {
                        <div class="mi-section-label mt-3 mb-1">Enchantment</div>
                        <p class="mi-recipe">@it.Recipe</p>
                    }
                </div>
            }
            else
            {
                <div class="qp-card p-4 text-muted text-center">Select a magic item.</div>
            }
        </div>
    </div>
</div>

<style>
    .mi-list { max-height: calc(100vh - 230px); overflow-y: auto; display: flex; flex-direction: column; }
    .mi-group-header { padding: 8px 14px 4px; font-size: .72rem; font-weight: 700;
                       text-transform: uppercase; letter-spacing: .06em; color: var(--qp-teal);
                       background: var(--qp-bg-panel-alt); border-bottom: 1px solid var(--qp-border-panel); }
    .mi-list-item { padding: 7px 14px; border-bottom: 1px solid var(--qp-border-panel);
                    cursor: pointer; color: var(--qp-text-primary); transition: background .12s; }
    .mi-list-item:hover  { background: var(--qp-bg-panel-alt); }
    .mi-list-item.active { background: var(--qp-blue); color: #fff; }
    .mi-title { color: var(--qp-teal); font-weight: 700; letter-spacing: .03em; }
    .mi-cat { color: var(--qp-text-muted); font-size: .82rem; }
    .mi-gm-tag { display: inline-block; padding: 0 5px; border-radius: 3px; font-size: .62rem;
                 font-weight: 700; letter-spacing: .04em; vertical-align: middle;
                 background: var(--qp-red, #b3402e); color: #fff; text-transform: uppercase; }
    .mi-created-tag { display: inline-block; padding: 0 5px; border-radius: 3px; font-size: .58rem;
                      font-weight: 700; letter-spacing: .04em; vertical-align: middle; margin-left: 6px;
                      background: var(--qp-blue, #2f6f9f); color: #fff; text-transform: uppercase; }
    .mi-stats { display: flex; flex-wrap: wrap; gap: 16px; }
    .mi-stat { font-size: .9rem; color: var(--qp-text-primary); }
    .mi-stat-label { font-size: .7rem; font-weight: 700; text-transform: uppercase;
                     letter-spacing: .05em; color: var(--qp-text-label); margin-right: 4px; }
    .mi-desc { color: var(--qp-text-primary); line-height: 1.6; font-size: .92rem; margin-bottom: 0; }
    .mi-section-label { font-size: .72rem; font-weight: 700; text-transform: uppercase;
                        letter-spacing: .06em; color: var(--qp-text-label); }
    .mi-recipe { color: var(--qp-text-muted); font-size: .86rem; line-height: 1.55;
                 font-family: var(--bs-font-monospace, monospace); margin-bottom: 0; }
</style>

@code {
    // Deep link from other pages (e.g. Random Treasure tables) to a specific item.
    [SupplyParameterFromQuery(Name = "item")]
    public string? ItemName { get; set; }

    private string _search = "";
    private string _categoryFilter = "";
    private MagicItem? _selected;

    protected override void OnParametersSet()
    {
        if (!string.IsNullOrEmpty(ItemName))
        {
            var found = Items.All.FirstOrDefault(
                i => string.Equals(i.Name, ItemName, StringComparison.OrdinalIgnoreCase));
            if (found is not null) { _selected = found; }
        }
    }

    // Display categories in the book's order rather than alphabetically.
    private static readonly string[] CategoryOrder =
    [
        "Daily Items", "Constant Items", "Emplaced Spell Items", "General Bonus Items",
        "Power Enhancers", "Skill Items", "Stat Bonus Items", "Armor & Shields",
        "Jewelry", "Melee Weapons", "Missile Weapons", "Potions", "Wands, Rods & Staves"
    ];

    private static int CategoryRank(string category)
    {
        var i = Array.IndexOf(CategoryOrder, category);
        return i < 0 ? int.MaxValue : i;
    }

    private IEnumerable<MagicItem> Filtered =>
        Items.Search(_search)
            .Where(i => string.IsNullOrEmpty(_categoryFilter) || i.Category == _categoryFilter);
}
