@page "/character/{Id:int}/wizard"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using RolemasterCharacterCreation.Data
@using RolemasterCharacterCreation.Models
@using RolemasterCharacterCreation.Identity
@using RolemasterCharacterCreation.Rules
@inject AppDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState
@attribute [Authorize]

<PageTitle>Character Wizard — @(_char?.Name ?? "...")</PageTitle>

@if (_char is null)
{
    <p>Loading…</p>
    return;
}

@if (!_authorized)
{
    <p class="text-danger">Access denied.</p>
    return;
}

<div class="container-fluid mt-3">
    <div class="qp-tabs mb-3">
        @if (_isLevelUp)
        {
            @foreach (var (idx, label) in LevelUpSteps)
            {
                <span class="qp-tab @(idx == _step ? "active" : idx < _step ? "done" : "")">
                    @if (idx < _step) { <span style="color:var(--qp-green);margin-right:3px">✓</span> }
                    @label
                </span>
            }
        }
        else
        {
            @foreach (var (label, idx) in Steps.Select((l, i) => (l, i)))
            {
                <span class="qp-tab @(idx == _step ? "active" : idx < _step ? "done" : "")">
                    @if (idx < _step) { <span style="color:var(--qp-green);margin-right:3px">✓</span> }
                    @label
                </span>
            }
        }
    </div>

    @if (!string.IsNullOrEmpty(_error))
    {
        <div class="alert alert-danger">@_error</div>
    }
    <div class="qp-panel">
    @switch (_step)
    {
        case 0: @StepConcept break;
        case 1: @(_isLevelUp ? StepStatGains : StepStats) break;
        case 2: @StepProfSkills break;
        case 3: @StepSkills break;
        case 4: @StepTalents break;
        case 5: @StepEquipment break;
    }
    </div>

    <div class="d-flex justify-content-between mt-4">
        @{
            bool isFirstStep = _isLevelUp ? _step == 1 : _step == 0;
            bool isLastStep  = _isLevelUp ? _step == 4 : _step == Steps.Length - 1;
        }
        <button class="btn btn-secondary" @onclick="PrevStep">@(_isLevelUp && _step == 1 ? "← Cancel" : "← Back")</button>
        @if (!isLastStep)
        {
            <button class="btn btn-primary" @onclick="NextStep">Next →</button>
        }
        else
        {
            <button class="btn btn-success" @onclick="FinishAsync">Finish</button>
        }
    </div>

</div>

@code {
    // ── Render fragments ──────────────────────────────────────────────────────

    static readonly string[] RaceNames = RaceRules.All.Select(r => r.Name).ToArray();
    static readonly string[] Realms    = ["Channeling", "Essence", "Mentalism"];

    RenderFragment StepConcept => __builder =>
    {
        var prof = ProfessionRules.ByName.GetValueOrDefault(_char!.Profession ?? "");
        var race = _char.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var rd) ? rd : null;

        <h4>Step 1: Concept</h4>
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label">Character Name</label>
                <input class="form-control" value="@_char!.Name"
                       @oninput="e => _char.Name = e.Value?.ToString() ?? _char.Name" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Race</label>
                <select class="form-select" @onchange="e => OnRaceChanged(e.Value?.ToString())">
                    <option value="">— select —</option>
                    @foreach (var r in RaceNames)
                    {
                        <option value="@r" selected="@(_char!.Race == r)">@r</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Culture</label>
                <select class="form-select"
                        @onchange="e => { _char!.Culture = e.Value?.ToString(); ApplyCulturalRanks(); }">
                    <option value="">— select —</option>
                    @foreach (var c in CultureRules.All)
                    {
                        <option value="@c.Name" selected="@(_char!.Culture == c.Name)">@c.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Profession</label>
                <select class="form-select" @onchange="e => OnProfessionChanged(e.Value?.ToString())">
                    <option value="">— select —</option>
                    @foreach (var p in ProfessionRules.All)
                    {
                        <option value="@p.Name" selected="@(_char!.Profession == p.Name)">
                            @p.Name — @p.Group@(p.Realm != null ? $" ({p.Realm})" : "")
                        </option>
                    }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">
                    Realm
                    @if (prof is { IsSpellcaster: false })
                    {
                        <span class="text-muted small ms-1">(+10 RR vs own realm)</span>
                    }
                </label>
                @if (prof?.Realm is { } fixedRealm && !fixedRealm.Contains("+"))
                {
                    <input class="form-control" value="@fixedRealm" disabled />
                }
                else
                {
                    <select class="form-select" @onchange="e => _char!.Realm = e.Value?.ToString()">
                        <option value="">— select —</option>
                        @foreach (var rl in Realms)
                        {
                            <option value="@rl" selected="@(_char!.Realm == rl)">@rl</option>
                        }
                    </select>
                }
            </div>

            <div class="col-md-4">
                <label class="form-label">Gender</label>
                <select class="form-select" @onchange="e => _char!.Gender = e.Value?.ToString()">
                    <option value="">— select —</option>
                    <option value="Male"   selected="@(_char!.Gender == "Male")">Male</option>
                    <option value="Female" selected="@(_char!.Gender == "Female")">Female</option>
                    <option value="Other"  selected="@(_char!.Gender == "Other")">Other</option>
                </select>
            </div>

            @if (_char!.Race is not null && _raceBuild.ContainsKey(_char.Race))
            {
                var heights = HeightOptions(_char.Race);
                var weights = WeightOptions(_char.Race);
                <div class="col-md-4">
                    <label class="form-label">Height (cm)</label>
                    <select class="form-select" @onchange="e => _char!.HeightCm = int.TryParse(e.Value?.ToString(), out int v) ? v : null">
                        <option value="">— select —</option>
                        @foreach (var h in heights)
                        {
                            <option value="@h" selected="@(_char!.HeightCm == h)">@FmtHeight(h)</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Weight (kg)</label>
                    <select class="form-select" @onchange="e => _char!.WeightKg = int.TryParse(e.Value?.ToString(), out int v) ? v : null">
                        <option value="">— select —</option>
                        @foreach (var w in weights)
                        {
                            <option value="@w" selected="@(_char!.WeightKg == w)">@FmtWeight(w)</option>
                        }
                    </select>
                </div>
            }

            <div class="col-md-4">
                <label class="form-label">Build</label>
                <select class="form-select" @onchange="e => _char!.Build = e.Value?.ToString()">
                    <option value="">— select —</option>
                    @foreach (var b in new[]{"Slim","Lean","Average","Athletic","Stocky","Muscular","Heavy"})
                    { <option value="@b" selected="@(_char!.Build == b)">@b</option> }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Age</label>
                <input type="number" class="form-control" min="1" max="5000"
                       value="@_char!.Age"
                       @onchange="e => _char!.Age = int.TryParse(e.Value?.ToString(), out int v) ? v : null" />
            </div>

            <div class="col-md-4">
                <label class="form-label">Hair Color</label>
                <select class="form-select" @onchange="e => _char!.HairColor = e.Value?.ToString()">
                    <option value="">— select —</option>
                    @foreach (var h in new[]{"Black","Dark Brown","Brown","Light Brown","Auburn","Red","Strawberry Blonde","Blonde","Dark Blonde","White","Silver/Grey","Bald"})
                    { <option value="@h" selected="@(_char!.HairColor == h)">@h</option> }
                </select>
            </div>

            <div class="col-md-4">
                <label class="form-label">Eye Color</label>
                <select class="form-select" @onchange="e => _char!.EyeColor = e.Value?.ToString()">
                    <option value="">— select —</option>
                    @foreach (var e2 in new[]{"Brown","Dark Brown","Hazel","Green","Blue","Grey","Amber","Black","Violet"})
                    { <option value="@e2" selected="@(_char!.EyeColor == e2)">@e2</option> }
                </select>
            </div>
        </div>

        @if (race is not null)
        {
            <div class="alert alert-info mt-3 py-2">
                <strong>@race.Name</strong>
                — Size: @race.Size, Base Hits: @race.BaseHits, Bonus DP: @race.BonusDP,
                  Endurance: @(race.EnduranceBonus >= 0 ? "+" : "")@race.EnduranceBonus,
                  Recovery: ×@race.RecoveryMult.ToString("0.0#")
                <div class="mt-1 small">
                    <strong>Stat mods:</strong>
                    @foreach (StatName sn in Enum.GetValues<StatName>())
                    {
                        int mod = race.GetStatMod(sn);
                        if (mod != 0)
                        {
                            <span class="me-2 @(mod > 0 ? "text-success" : "text-danger")">
                                @sn: @(mod > 0 ? "+" : "")@mod
                            </span>
                        }
                    }
                </div>
                <div class="mt-1 small">
                    <strong>RR mods:</strong>
                    <span class="me-2">Ch: @(race.ResistChanneling >= 0 ? "+" : "")@race.ResistChanneling</span>
                    <span class="me-2">Es: @(race.ResistEssence >= 0 ? "+" : "")@race.ResistEssence</span>
                    <span class="me-2">Mn: @(race.ResistMentalism >= 0 ? "+" : "")@race.ResistMentalism</span>
                    <span class="me-2">Ph: @(race.ResistPhysical >= 0 ? "+" : "")@race.ResistPhysical</span>
                </div>
            </div>
        }

        @if (!string.IsNullOrEmpty(_char!.Culture) && CultureRules.ByName.TryGetValue(_char.Culture, out var cult))
        {
            <h6 class="mt-3">Cultural Starting Ranks</h6>
            <ul class="small mb-2">
                @foreach (var sk in cult.Skills.Where(s => s.Ranks > 0 && !s.IsPool))
                {
                    <li>@sk.Skill: @sk.Ranks rank@(sk.Ranks != 1 ? "s" : "")@(sk.Specialized ? "*" : "")</li>
                }
            </ul>

            @foreach (var poolSk in cult.Skills.Where(s => s.IsPool && s.Ranks > 0))
            {
                int poolUsed = PoolUsed(poolSk.Skill);
                int poolRemaining = poolSk.Ranks - poolUsed;
                var eligibleSkills = GetPoolSkills(poolSk.Skill).ToList();
                bool perSkillCap = poolSk.Skill is "Composition/Performance" or "Crafting/Vocation";
                int rankMax = perSkillCap ? Math.Min(poolRemaining, 2) : poolRemaining;
                <div class="card mb-2">
                    <div class="card-header py-1 d-flex justify-content-between align-items-center">
                        <span>
                            <strong>@poolSk.Skill pool</strong>
                            @if (eligibleSkills.Any())
                            {
                                <span class="text-muted small ms-2">(@string.Join(", ", eligibleSkills))</span>
                            }
                        </span>
                        <span class="badge @(poolRemaining > 0 ? "bg-warning text-dark" : "bg-success")">
                            @poolUsed / @poolSk.Ranks ranks used
                        </span>
                    </div>
                    <div class="card-body py-2">
                        @if (_poolAllocs.TryGetValue(poolSk.Skill, out var entries) && entries.Any())
                        {
                            <ul class="list-unstyled small mb-2">
                                @foreach (var entry in entries.ToList())
                                {
                                    <li class="d-flex align-items-center gap-2 mb-1">
                                        <span>@entry.SkillName@(entry.Specialization is not null ? $" ({entry.Specialization})" : ""): @entry.Ranks rank@(entry.Ranks != 1 ? "s" : "")</span>
                                        <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemovePoolEntry(poolSk.Skill, entry)">×</button>
                                    </li>
                                }
                            </ul>
                        }
                        @if (poolRemaining > 0)
                        {
                            @if (_activePoolAdd == poolSk.Skill)
                            {
                                <div class="d-flex flex-wrap gap-2 align-items-end">
                                    <div>
                                        <label class="form-label form-label-sm mb-0">Skill</label>
                                        <select class="form-select form-select-sm" style="min-width:180px"
                                                @onchange="e => { _poolAddSkill = e.Value?.ToString() ?? string.Empty; _poolAddSpec = string.Empty; }">
                                            <option value="">— select —</option>
                                            @foreach (var ps in eligibleSkills)
                                            {
                                                <option value="@ps" selected="@(_poolAddSkill == ps)">@ps</option>
                                            }
                                        </select>
                                    </div>
                                    @if (!string.IsNullOrEmpty(_poolAddSkill) && PoolSkillNeedsSpec(_poolAddSkill))
                                    {
                                        var hasPoolOpts = SkillRules.SpecializationOptions.TryGetValue(_poolAddSkill, out var poolSpecOpts);
                                        var poolDlId = "pool-spec-" + _poolAddSkill.Replace(" ", "-").Replace("/", "-");
                                        <div>
                                            <label class="form-label form-label-sm mb-0">Specialization</label>
                                            <input class="form-control form-control-sm" style="min-width:140px"
                                                   list="@(hasPoolOpts ? poolDlId : null)"
                                                   placeholder="@(_poolAddSkill == "Language" ? "e.g. Common, Elvish" : "e.g. Drums, Bounty Hunter")"
                                                   value="@_poolAddSpec"
                                                   @oninput="e => _poolAddSpec = e.Value?.ToString() ?? string.Empty" />
                                            @if (hasPoolOpts)
                                            {
                                                <datalist id="@poolDlId">
                                                    @foreach (var opt in poolSpecOpts!)
                                                    { <option value="@opt" /> }
                                                </datalist>
                                            }
                                        </div>
                                    }
                                    <div>
                                        <label class="form-label form-label-sm mb-0">Ranks@(perSkillCap ? " (max 2)" : "")</label>
                                        <input type="number" class="form-control form-control-sm" style="width:70px"
                                               min="1" max="@rankMax"
                                               value="@_poolAddRanks"
                                               @onchange="e => _poolAddRanks = int.TryParse(e.Value?.ToString(), out int v) ? v : 1" />
                                    </div>
                                    <button class="btn btn-sm btn-success" @onclick="() => AddPoolEntry(poolSk.Skill, poolSk.Ranks)">Add</button>
                                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => _activePoolAdd = null">Cancel</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => { _activePoolAdd = poolSk.Skill; _poolAddSkill = string.Empty; _poolAddSpec = string.Empty; _poolAddRanks = 1; }">+ Add</button>
                            }
                        }
                    </div>
                </div>
            }
        }
    };

    RenderFragment StepStats => __builder =>
    {
        var race = _char?.Race is not null && RaceRules.ByName.TryGetValue(_char.Race, out var rd) ? rd : null;
        <h4>Step 2: Generate Stats</h4>
        <div class="mb-3">
            <button class="btn btn-outline-primary me-2" @onclick="RollAllStats">Roll All Stats</button>
            <span class="text-muted small">Boosts remaining: @_boostsRemaining | Swaps remaining: @_swapsRemaining</span>
        </div>
        @if (_pendingBoostType is not null)
        {
            <div class="alert alert-warning py-2">
                @(_pendingBoostType == 0 ? "Click Apply on the stat row you want set to 56/78:" : "Click Apply on the stat row for 2 gain rolls:")
                <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="() => _pendingBoostType = null">Cancel</button>
            </div>
        }
        @if (_rolls.Any())
        {
            <div class="mb-3">
                <strong>Boosts</strong>
                <div class="btn-group ms-2">
                    <button class="btn btn-sm btn-outline-secondary"
                            disabled="@(_boostsRemaining == 0 || _pendingBoostType is not null)"
                            @onclick="() => ApplyBoost(0)">56/78 (choose stat)</button>
                    <button class="btn btn-sm btn-outline-secondary"
                            disabled="@(_boostsRemaining == 0 || _pendingBoostType is not null)"
                            @onclick="() => ApplyBoost(1)">Top→90+10pot</button>
                    <button class="btn btn-sm btn-outline-secondary"
                            disabled="@(_boostsRemaining == 0 || _pendingBoostType is not null)"
                            @onclick="() => ApplyBoost(2)">2nd→85+10pot</button>
                    <button class="btn btn-sm btn-outline-secondary"
                            disabled="@(_boostsRemaining == 0 || _pendingBoostType is not null)"
                            @onclick="() => ApplyBoost(3)">2 gain rolls (choose stat)</button>
                </div>
            </div>
        }
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Stat</th><th>Temp</th><th>Potential</th><th>Racial</th><th>Special</th><th>Effective Bonus</th><th>Swap</th>
                    @if (_pendingBoostType is not null) { <th>Boost</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (StatName sn in Enum.GetValues<StatName>())
                {
                    int temp = GetTemp(sn), pot = GetPotential(sn);
                    int racial = race?.GetStatMod(sn) ?? 0;
                    var statObj = _char!.Stats.FirstOrDefault(s => s.Stat == sn);
                    int special = statObj?.Special ?? 0;
                    int effective = SkillRules.StatBonus(temp) + racial + special;
                    <tr class="@(_swapA == sn ? "table-warning" : _pendingBoostType is not null ? "table-active" : "")">
                        <td>@sn</td>
                        <td>
                            <input type="number" class="form-control form-control-sm" style="width:80px" min="1" max="100"
                                   value="@temp"
                                   @onchange="e => { int v = int.TryParse(e.Value?.ToString(), out int x) ? x : temp; _rolls[sn] = new StatRoll(v, GetPotential(sn)); }" />
                        </td>
                        <td>
                            <input type="number" class="form-control form-control-sm" style="width:80px" min="1" max="100"
                                   value="@pot"
                                   @onchange="e => { int v = int.TryParse(e.Value?.ToString(), out int x) ? x : pot; _rolls[sn] = new StatRoll(GetTemp(sn), v); }" />
                        </td>
                        <td class="@(racial > 0 ? "text-success" : racial < 0 ? "text-danger" : "text-muted")">
                            @(racial == 0 ? "—" : racial > 0 ? $"+{racial}" : racial.ToString())
                        </td>
                        <td>
                            @if (statObj is not null)
                            {
                                <input type="number" class="form-control form-control-sm" style="width:70px"
                                       value="@special"
                                       @onchange="e => { if (statObj is not null) statObj.Special = int.TryParse(e.Value?.ToString(), out int x) ? x : 0; }" />
                            }
                        </td>
                        <td class="@(effective >= 0 ? "text-success" : "text-danger")">
                            @(effective >= 0 ? "+" : "")@effective
                        </td>
                        <td>
                            <button class="btn btn-sm @(_swapA == sn ? "btn-warning" : "btn-outline-secondary")"
                                    disabled="@(_swapsRemaining == 0 && _swapA != sn)"
                                    @onclick="() => StartSwap(sn)">
                                @(_swapA == sn ? "Cancel" : "Swap")
                            </button>
                        </td>
                        @if (_pendingBoostType is not null)
                        {
                            <td><button class="btn btn-sm btn-primary" @onclick="() => ApplyBoostToStat(sn)">Apply</button></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
        <p class="small text-muted">Tip: Click "Swap" on two stats to exchange their Temp/Potential pair.</p>
    };

    RenderFragment StepStatGains => __builder =>
    {
        <h6 class="text-secondary mb-3">Level @_char!.Level Stat Gain Rolls</h6>
        <p class="small text-muted mb-3">
            Roll open-ended d100 for each stat. If the result exceeds your current Temporary value, the stat gains +1.
            If Temp reaches Potential, Potential also increases by 1.
            Use <em>Auto-Roll</em> to let the system roll, or enter your own die result in the input and click <em>Apply</em>.
        </p>
        <table class="table table-sm table-bordered align-middle">
            <thead>
                <tr>
                    <th style="width:8%">Stat</th>
                    <th class="text-center" style="width:10%">Temp</th>
                    <th class="text-center" style="width:10%">Potential</th>
                    <th class="text-center" style="width:18%">Auto-Roll</th>
                    <th class="text-center" style="width:30%">Manual Roll</th>
                    <th class="text-center">Result</th>
                </tr>
            </thead>
            <tbody>
                @foreach (StatName sn in Enum.GetValues<StatName>())
                {
                    var stat = _char.Stats.FirstOrDefault(s => s.Stat == sn);
                    if (stat is null) continue;
                    bool rolled = _statGainRolls.TryGetValue(sn, out var gr);
                    <tr>
                        <td><strong>@sn</strong></td>
                        <td class="text-center">@stat.Temporary</td>
                        <td class="text-center">@stat.Potential</td>
                        <td class="text-center">
                            <button class="btn btn-sm btn-outline-secondary" @onclick="() => RollStatGain(sn)">
                                @(rolled ? "Re-roll" : "Roll")
                            </button>
                        </td>
                        <td class="text-center">
                            <div class="d-flex align-items-center justify-content-center gap-1">
                                <input type="number" class="form-control form-control-sm" style="width:72px"
                                       min="1"
                                       value="@(_manualRollInputs.GetValueOrDefault(sn, string.Empty))"
                                       @onchange="@(e => _manualRollInputs[sn] = e.Value?.ToString() ?? string.Empty)"
                                       placeholder="d100" />
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => ApplyManualRoll(sn)">Apply</button>
                            </div>
                        </td>
                        <td class="text-center">
                            @if (rolled)
                            {
                                @if (gr.Gained)
                                {
                                    <span class="text-success fw-bold">@gr.Roll ✓ +1</span>
                                }
                                else
                                {
                                    <span class="text-muted">@gr.Roll — no gain</span>
                                }
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <button class="btn btn-sm btn-outline-primary" @onclick="RollAllStatGains">Roll All Remaining</button>
    };

    RenderFragment StepProfSkills => __builder =>
    {
        var prof = ProfessionRules.ByName.GetValueOrDefault(_char?.Profession ?? "");
        if (prof is null)
        {
            <p class="text-warning">Please select a profession in Step 1 first.</p>
            return;
        }
        <h4>Step 3: Professional Skills</h4>
        <p class="text-muted">Choose <strong>10 Professional Skills</strong> and <strong>2 Knacks</strong> from the list below.</p>
        <p>
            Pro selected: <strong>@_chosenPro.Count / 10</strong> |
            Knacks selected: <strong>@_chosenKnack.Count / 2</strong>
        </p>
        <div class="row row-cols-1 row-cols-md-2 g-2">
            @foreach (var skillName in prof.ProfessionalSkills)
            {
                bool isPro = _chosenPro.Contains(skillName);
                bool isKnack = _chosenKnack.Contains(skillName);
                string _profSkTip = SkillRules.SkillByName.TryGetValue(skillName, out var _profSkDef) ? _profSkDef.Description : "";
                <div class="col">
                    <div class="card @(isPro || isKnack ? "border-primary" : "") p-2">
                        <div class="d-flex align-items-center justify-content-between">
                            <span data-bs-toggle="tooltip" data-bs-title="@_profSkTip" data-bs-placement="right">@skillName</span>
                            <div class="btn-group btn-group-sm">
                                <button class="btn @(isPro ? "btn-primary" : "btn-outline-primary")"
                                        @onclick="() => TogglePro(skillName)">Pro</button>
                                <button class="btn @(isKnack ? "btn-warning" : "btn-outline-warning")"
                                        @onclick="() => ToggleKnack(skillName)">Knack</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    };

    void TogglePro(string skillName)
    {
        if (_chosenPro.Contains(skillName)) { _chosenPro.Remove(skillName); return; }
        _chosenKnack.Remove(skillName);
        if (_chosenPro.Count < 10) _chosenPro.Add(skillName);
    }

    void ToggleKnack(string skillName)
    {
        if (_chosenKnack.Contains(skillName)) { _chosenKnack.Remove(skillName); return; }
        _chosenPro.Remove(skillName);
        if (_chosenKnack.Count < 2) _chosenKnack.Add(skillName);
    }

    RenderFragment StepSkills => __builder =>
    {
        var prof = ProfessionRules.ByName.GetValueOrDefault(_char?.Profession ?? "");
        <h4>Step 4: Purchase Skills</h4>
        <p class="mb-1">
            DP Budget: <strong>@_dpBudget</strong> |
            Spent: <strong>@_dpSpent</strong> |
            Remaining: <strong class="@(_dpBudget - _dpSpent < 0 ? "text-danger" : "text-success")">@(_dpBudget - _dpSpent)</strong>
        </p>

        @foreach (var cat in SkillRules.Categories)
        {
            <div class="skills-section">
                <div class="qp-cat-header">
                    @cat.Name
                    @if (!cat.NoStats)
                    {
                        <span class="ms-2 text-muted">(@cat.Stat1 + @cat.Stat2)</span>
                    }
                    @if (cat.Name != "Spellcasting")
                    {
                        var catKey = ResolveCostKey(cat.Name);
                        (int f, int s) catCost = prof is not null && prof.Costs.TryGetValue(catKey, out var cc) ? cc : (99, 99);
                        <span class="ms-2 badge bg-secondary">@catCost.f / @catCost.s DP</span>
                    }
                    else
                    {
                        <span class="ms-2 badge bg-secondary">varies by list type</span>
                    }
                </div>
                <table class="table table-hover mb-0" style="table-layout:fixed">
                    <thead>
                        <tr>
                            <th style="width:30%">Skill</th>
                            <th class="text-center" style="width:14%">Cultural</th>
                            <th class="text-center" style="width:14%">Bought</th>
                            <th class="text-center" style="width:14%">Total</th>
                            <th class="text-center" style="width:14%">Bonus</th>
                            <th class="text-center" style="width:14%">Ranks</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var sk in cat.Skills)
                        {
                            int cultural  = GetCulturalRanks(sk.Name);
                            bool isPro    = _chosenPro.Contains(sk.Name);
                            bool isKnack  = _chosenKnack.Contains(sk.Name);

                            int baseStatBonus = cat.NoStats ? 0
                                : SkillRules.StatBonus(GetTemp(ResolveStatForBonus(cat.Stat1)))
                                  + SkillRules.StatBonus(GetTemp(ResolveStatForBonus(cat.Stat2)))
                                  + (sk.SkillStat is "" or "R*" or "St or Ag" ? 0 : SkillRules.StatBonus(GetTemp(ResolveStatForBonus(sk.SkillStat))));
                            int racialStatBonus = cat.NoStats ? 0
                                : GetRacialMod(ResolveStatForBonus(cat.Stat1))
                                  + GetRacialMod(ResolveStatForBonus(cat.Stat2))
                                  + (sk.SkillStat is "" or "R*" or "St or Ag" ? 0 : GetRacialMod(ResolveStatForBonus(sk.SkillStat)));

                            if (cat.Name == "Spellcasting" && sk.Name.EndsWith("Spell Lists"))
                            {
                                int totalListRanks = _spellAllocs.Where(s => s.SkillName == sk.Name).Sum(s => s.Ranks);
                                var slCostKey = ResolveSpellCostKey(sk.Name);
                                (int slf, int sls) slCost = prof is not null && prof.Costs.TryGetValue(slCostKey, out var slct) ? slct : (99, 99);

                                <tr>
                                    <td>
                                        <span data-bs-toggle="tooltip" data-bs-title="@sk.Description" data-bs-placement="right">@sk.Name</span>
                                        @if (isPro)   { <span class="badge bg-primary ms-1">Pro</span> }
                                        @if (isKnack) { <span class="badge bg-warning text-dark ms-1">Knack</span> }
                                    </td>
                                    <td class="text-center text-muted">@cultural</td>
                                    <td class="text-center">@totalListRanks</td>
                                    <td class="text-center"><strong>@(cultural + totalListRanks)</strong></td>
                                    <td class="text-center text-muted">—</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => { _activeSpellAdd = _activeSpellAdd == sk.Name ? null : sk.Name; _spellAddName = string.Empty; _spellAddRanks = 1; }">
                                            @(_activeSpellAdd == sk.Name ? "Cancel" : "+ Add")
                                        </button>
                                    </td>
                                </tr>

                                @foreach (var sa in _spellAllocs.Where(s => s.SkillName == sk.Name).ToList())
                                {
                                    int saTotal = sa.Ranks;
                                    int saBonus = baseStatBonus + racialStatBonus
                                        + SkillRules.RankBonus(saTotal)
                                        + (isPro ? Math.Min(saTotal, 30) : 0)
                                        + (isKnack ? 5 : 0);
                                    <tr class="qp-sub-row">
                                        <td class="ps-4">
                                            ↳ @sa.Specialization
                                            <small class="text-muted ms-1">@slCost.slf / @slCost.sls dp</small>
                                        </td>
                                        <td class="text-center text-muted">—</td>
                                        <td class="text-center">@sa.Ranks</td>
                                        <td class="text-center"><strong>@saTotal</strong></td>
                                        <td class="text-center @(saBonus >= 0 ? "text-success" : "text-danger")">@(saBonus >= 0 ? "+" : "")@saBonus</td>
                                        <td class="text-center" style="white-space:nowrap">
                                            <button class="btn qp-btn-minus"
                                                    @onclick="() => AdjSpellRanks(sa, -1)">−</button>
                                            <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@sa.Ranks</span>
                                            <button class="btn qp-btn-plus"
                                                    disabled="@(NewSpellRanksThisLevel(sa) >= 2 || _dpBudget - _dpSpent < slCost.sls)"
                                                    @onclick="() => AdjSpellRanks(sa, 1)">+</button>
                                        </td>
                                    </tr>
                                }

                                @if (_activeSpellAdd == sk.Name)
                                {
                                    var spellRealm = _char!.Realm
                                        ?? ProfessionRules.ByName.GetValueOrDefault(_char.Profession ?? "")?.Realm;
                                    var availableSpellLists = SpellListRules.GetAvailableLists(sk.Name, spellRealm, _char.Profession)
                                        .Where(l => !_spellAllocs.Any(s => s.SkillName == sk.Name && s.Specialization == l))
                                        .ToList();
                                    var dlId = $"dl-{sk.Name.Replace(" ", "-").ToLower()}";
                                    <tr>
                                        <td colspan="6">
                                            <div class="d-flex flex-wrap gap-2 align-items-end py-1">
                                                <div>
                                                    <label class="form-label form-label-sm mb-0">
                                                        List Name <small class="text-muted">(@slCost.slf / @slCost.sls dp per rank)</small>
                                                    </label>
                                                    <input class="form-control form-control-sm" style="min-width:220px"
                                                           list="@dlId"
                                                           placeholder="Select or type list name"
                                                           value="@_spellAddName"
                                                           @oninput="e => _spellAddName = e.Value?.ToString() ?? string.Empty" />
                                                    <datalist id="@dlId">
                                                        @foreach (var ln in availableSpellLists)
                                                        {
                                                            <option value="@ln" />
                                                        }
                                                    </datalist>
                                                </div>
                                                <div>
                                                    <label class="form-label form-label-sm mb-0">Ranks</label>
                                                    <input type="number" class="form-control form-control-sm" style="width:70px"
                                                           min="1" max="2"
                                                           value="@_spellAddRanks"
                                                           @onchange="e => _spellAddRanks = int.TryParse(e.Value?.ToString(), out int v) ? v : 1" />
                                                </div>
                                                <button class="btn btn-sm btn-success"
                                                        disabled="@(string.IsNullOrWhiteSpace(_spellAddName))"
                                                        @onclick="() => AddSpellAlloc(sk.Name)">Add</button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => _activeSpellAdd = null">Cancel</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else if (IsGenericSpecialized(sk.Name))
                            {
                                var genCostKey = ResolveCostKey(cat.Name, sk.Name);
                                (int genf, int gens) genCost = prof is not null && prof.Costs.TryGetValue(genCostKey, out var gct) ? gct : (99, 99);

                                var culturalSpecs = _char!.Skills
                                    .Where(s => s.SkillName == sk.Name && s.Specialization != null)
                                    .ToList();
                                var allSpecs = culturalSpecs.Select(s => s.Specialization!)
                                    .Union(_genericAllocs.Where(g => g.SkillName == sk.Name).Select(g => g.Specialization))
                                    .Distinct()
                                    .ToList();

                                int totalCultural  = culturalSpecs.Sum(s => s.CulturalRanks);
                                int totalPurchased = _genericAllocs.Where(g => g.SkillName == sk.Name).Sum(g => g.Ranks);

                                <tr>
                                    <td>
                                        <span data-bs-toggle="tooltip" data-bs-title="@sk.Description" data-bs-placement="right">@sk.Name</span>
                                        @if (isPro)   { <span class="badge bg-primary ms-1">Pro</span> }
                                        @if (isKnack) { <span class="badge bg-warning text-dark ms-1">Knack</span> }
                                        <small class="ms-1 text-muted">(@genCost.genf/@genCost.gens DP)</small>
                                    </td>
                                    <td class="text-center text-muted">@totalCultural</td>
                                    <td class="text-center">@totalPurchased</td>
                                    <td class="text-center"><strong>@(totalCultural + totalPurchased)</strong></td>
                                    <td></td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => { _genericAddSkill = _genericAddSkill == sk.Name ? string.Empty : sk.Name; _genericAddSpec = string.Empty; }">
                                            @(_genericAddSkill == sk.Name ? "Cancel" : "+ Add")
                                        </button>
                                    </td>
                                </tr>

                                @foreach (var spec in allSpecs)
                                {
                                    var specCultural = culturalSpecs.FirstOrDefault(s => s.Specialization == spec)?.CulturalRanks ?? 0;
                                    var ga = _genericAllocs.FirstOrDefault(g => g.SkillName == sk.Name && g.Specialization == spec);
                                    int gaPurchased = ga?.Ranks ?? 0;
                                    int gaTotal = specCultural + gaPurchased;
                                    int gaNewRanks = ga is not null ? NewGenericRanksThisLevel(ga) : 0;
                                    int gaMinRanks = _baselineGenericAllocs.GetValueOrDefault((sk.Name, spec), 0);
                                    int gaBonus = baseStatBonus + racialStatBonus
                                        + SkillRules.RankBonus(gaTotal)
                                        + (isPro ? Math.Min(gaTotal, 30) : 0)
                                        + (isKnack ? 5 : 0);

                                    <tr>
                                        <td class="ps-4"><small class="text-muted">↳</small> @spec</td>
                                        <td class="text-center text-muted">@specCultural</td>
                                        <td class="text-center">@gaPurchased</td>
                                        <td class="text-center"><strong>@gaTotal</strong></td>
                                        <td class="text-center @(gaBonus >= 0 ? "text-success" : "text-danger")">@(gaBonus >= 0 ? "+" : "")@gaBonus</td>
                                        <td class="text-center" style="white-space:nowrap">
                                            @if (ga is not null)
                                            {
                                                <button class="btn qp-btn-minus"
                                                        disabled="@(gaPurchased <= gaMinRanks)"
                                                        @onclick="() => AdjGenericRanks(ga, -1)">−</button>
                                                <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@gaPurchased</span>
                                                <button class="btn qp-btn-plus"
                                                        disabled="@(gaNewRanks >= 2 || (_dpBudget - _dpSpent < (gaNewRanks == 0 ? genCost.genf : genCost.gens)))"
                                                        @onclick="() => AdjGenericRanks(ga, 1)">+</button>
                                            }
                                        </td>
                                    </tr>
                                }

                                @if (_genericAddSkill == sk.Name)
                                {
                                    var hasGenOpts = SkillRules.SpecializationOptions.TryGetValue(sk.Name, out var genOpts);
                                    var genDlId = "gen-dl-" + sk.Name.Replace(" ", "-").Replace("/", "-");
                                    <tr>
                                        <td colspan="6">
                                            <div class="d-flex gap-2 align-items-end py-1">
                                                <div>
                                                    <label class="form-label form-label-sm mb-0">Specialization</label>
                                                    <input class="form-control form-control-sm" style="min-width:160px"
                                                           list="@(hasGenOpts ? genDlId : null)"
                                                           placeholder="@(sk.Name == "Language" ? "e.g. Common, Elvish" : "specialization")"
                                                           value="@_genericAddSpec"
                                                           @oninput="e => _genericAddSpec = e.Value?.ToString() ?? string.Empty" />
                                                    @if (hasGenOpts)
                                                    {
                                                        <datalist id="@genDlId">
                                                            @foreach (var opt in genOpts!)
                                                            { <option value="@opt" /> }
                                                        </datalist>
                                                    }
                                                </div>
                                                <button class="btn btn-sm btn-success"
                                                        disabled="@(string.IsNullOrWhiteSpace(_genericAddSpec) || allSpecs.Contains(_genericAddSpec.Trim()))"
                                                        @onclick="AddGenericAlloc">Add</button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => { _genericAddSkill = string.Empty; _genericAddSpec = string.Empty; }">Cancel</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else if (WeaponRules.BySkill.ContainsKey(sk.Name))
                            {
                                int weaponPurchased = GetWeaponPurchased(sk.Name);
                                int weaponTotal     = cultural + weaponPurchased;

                                <tr>
                                    <td>
                                        <span data-bs-toggle="tooltip" data-bs-title="@sk.Description" data-bs-placement="right">@sk.Name</span>
                                        @if (isPro)   { <span class="badge bg-primary ms-1">Pro</span> }
                                        @if (isKnack) { <span class="badge bg-warning text-dark ms-1">Knack</span> }
                                    </td>
                                    <td class="text-center text-muted">@cultural</td>
                                    <td class="text-center">@weaponPurchased</td>
                                    <td class="text-center"><strong>@weaponTotal</strong></td>
                                    <td class="text-center text-muted">—</td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => { _activeWeaponAdd = _activeWeaponAdd == sk.Name ? null : sk.Name; _weaponAddSpec = string.Empty; _weaponAddRanks = 1; }">
                                            @(_activeWeaponAdd == sk.Name ? "Cancel" : "+ Add")
                                        </button>
                                    </td>
                                </tr>

                                @foreach (var wa in _weaponAllocs.Where(w => w.SkillName == sk.Name).ToList())
                                {
                                    int waSlot    = _weaponAllocs.IndexOf(wa);
                                    var waKey     = WeaponRules.CostKeyForSlot(waSlot);
                                    (int wf, int ws) waCost = prof is not null && prof.Costs.TryGetValue(waKey, out var wct) ? wct : (99, 99);
                                    int waTotal   = cultural + wa.Ranks;
                                    int waBonus   = baseStatBonus + racialStatBonus
                                        + SkillRules.RankBonus(waTotal)
                                        + (isPro ? Math.Min(waTotal, 30) : 0)
                                        + (isKnack ? 5 : 0);
                                    <tr class="qp-sub-row">
                                        <td class="ps-4">
                                            ↳ @wa.Specialization
                                            <span class="badge bg-secondary ms-1">slot @(waSlot + 1)</span>
                                            <small class="text-muted ms-1">@waCost.wf / @waCost.ws dp</small>
                                        </td>
                                        <td class="text-center text-muted">@(cultural > 0 ? cultural.ToString() : "—")</td>
                                        <td class="text-center">@wa.Ranks</td>
                                        <td class="text-center"><strong>@waTotal</strong></td>
                                        <td class="text-center @(waBonus >= 0 ? "text-success" : "text-danger")">@(waBonus >= 0 ? "+" : "")@waBonus</td>
                                        <td class="text-center" style="white-space:nowrap">
                                            <button class="btn qp-btn-minus"
                                                    @onclick="() => AdjWeaponRanks(wa, -1)">−</button>
                                            <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@wa.Ranks</span>
                                            <button class="btn qp-btn-plus"
                                                    disabled="@(NewWeaponRanksThisLevel(wa) >= 2 || _dpBudget - _dpSpent < waCost.ws)"
                                                    @onclick="() => AdjWeaponRanks(wa, 1)">+</button>
                                        </td>
                                    </tr>
                                }

                                @if (_activeWeaponAdd == sk.Name)
                                {
                                    var availableWeapons = WeaponRules.BySkill[sk.Name]
                                        .Where(w => !_weaponAllocs.Any(wa => wa.Specialization == w.Name))
                                        .ToList();
                                    int nextSlot = _weaponAllocs.Count;
                                    (int nf, int ns) nextCost = prof is not null && prof.Costs.TryGetValue(WeaponRules.CostKeyForSlot(nextSlot), out var nct) ? nct : (99, 99);
                                    <tr>
                                        <td colspan="6">
                                            <div class="d-flex flex-wrap gap-2 align-items-end py-1">
                                                <div>
                                                    <label class="form-label form-label-sm mb-0">Weapon <small class="text-muted">(slot @(nextSlot+1): @nextCost.nf / @nextCost.ns dp)</small></label>
                                                    <select class="form-select form-select-sm" style="min-width:200px"
                                                            @onchange="e => _weaponAddSpec = e.Value?.ToString() ?? string.Empty">
                                                        <option value="">— select —</option>
                                                        @foreach (var wd in availableWeapons)
                                                        {
                                                            <option value="@wd.Name" selected="@(_weaponAddSpec == wd.Name)">@wd.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div>
                                                    <label class="form-label form-label-sm mb-0">Ranks</label>
                                                    <input type="number" class="form-control form-control-sm" style="width:70px"
                                                           min="1" max="2"
                                                           value="@_weaponAddRanks"
                                                           @onchange="e => _weaponAddRanks = int.TryParse(e.Value?.ToString(), out int v) ? v : 1" />
                                                </div>
                                                <button class="btn btn-sm btn-success"
                                                        disabled="@(string.IsNullOrEmpty(_weaponAddSpec))"
                                                        @onclick="() => AddWeaponAlloc(sk.Name)">Add</button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="() => _activeWeaponAdd = null">Cancel</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                int purchased = GetPurchased(sk.Name);
                                int total     = cultural + purchased;
                                int bonus     = baseStatBonus + racialStatBonus
                                    + SkillRules.RankBonus(total)
                                    + (isPro ? Math.Min(total, 30) : 0)
                                    + (isKnack ? 5 : 0);

                                var skCostKey = ResolveCostKey(cat.Name, sk.Name);
                                (int first, int second) cost = prof is not null && prof.Costs.TryGetValue(skCostKey, out var sc) ? sc : (99, 99);

                                <tr>
                                    <td>
                                        <span data-bs-toggle="tooltip" data-bs-title="@sk.Description" data-bs-placement="right">@sk.Name</span>
                                        @if (isPro)   { <span class="badge bg-primary ms-1">Pro</span> }
                                        @if (isKnack) { <span class="badge bg-warning text-dark ms-1">Knack</span> }
                                        @if (cat.Name == "Spellcasting")
                                        {
                                            <small class="ms-1 text-muted">(@cost.first/@cost.second DP)</small>
                                        }
                                    </td>
                                    <td class="text-center text-muted">@cultural</td>
                                    <td class="text-center">@purchased</td>
                                    <td class="text-center"><strong>@total</strong></td>
                                    <td class="text-center @(bonus >= 0 ? "text-success" : "text-danger")">@(bonus >= 0 ? "+" : "")@bonus</td>
                                    <td class="text-center" style="white-space:nowrap">
                                        <button class="btn qp-btn-minus"
                                                disabled="@(purchased <= MinPurchasedRanks(sk.Name))"
                                                @onclick="() => ChangeRanks(sk.Name, -1)">−</button>
                                        <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@purchased</span>
                                        <button class="btn qp-btn-plus"
                                                disabled="@(NewRanksThisLevel(sk.Name) >= 2 || (_dpBudget - _dpSpent < cost.first && NewRanksThisLevel(sk.Name) == 0) || (_dpBudget - _dpSpent < cost.second && NewRanksThisLevel(sk.Name) >= 1))"
                                                @onclick="() => ChangeRanks(sk.Name, 1)">+</button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        }
    };

    void ChangeRanks(string skillName, int delta)
    {
        int cur  = GetPurchased(skillName);
        int min  = MinPurchasedRanks(skillName);
        int next = Math.Max(min, cur + delta);
        if (next == cur) return;

        if (delta > 0)
        {
            int newRanksCur = NewRanksThisLevel(skillName);
            if (newRanksCur >= 2) return; // max 2 new ranks per level
            var prof = ProfessionRules.ByName.GetValueOrDefault(_char?.Profession ?? "");
            var cat  = SkillRules.CategoryOf(skillName);
            if (prof is null || cat is null) return;
            var costKey = ResolveCostKey(cat.Name, skillName);
            if (!prof.Costs.TryGetValue(costKey, out var c)) return;
            int addCost = newRanksCur == 0 ? c.First : c.Second;
            if (_dpBudget - _dpSpent < addCost) return;
        }
        SetPurchased(skillName, next);
    }

    static StatName StatFromName(string s) => s switch
    {
        "Ag" => StatName.Ag,
        "Co" => StatName.Co,
        "Em" => StatName.Em,
        "In" => StatName.In,
        "Me" => StatName.Me,
        "Pr" => StatName.Pr,
        "Qu" => StatName.Qu,
        "Re" => StatName.Re,
        "SD" => StatName.SD,
        "St" => StatName.St,
        _    => StatName.Co
    };

    // Resolves R* to the character's actual realm stat per Core Law §2.4.
    // Hybrid casters use the lower of their two realm stats.
    StatName GetRealmStat()
    {
        var realm = _char?.Realm
            ?? ProfessionRules.ByName.GetValueOrDefault(_char?.Profession ?? "")?.Realm;
        bool ch = realm?.Contains("Channeling") == true;
        bool es = realm?.Contains("Essence")    == true;
        bool me = realm?.Contains("Mentalism")  == true;
        if (ch && me) return SkillRules.StatBonus(GetTemp(StatName.In)) <= SkillRules.StatBonus(GetTemp(StatName.Pr)) ? StatName.In : StatName.Pr;
        if (es && me) return SkillRules.StatBonus(GetTemp(StatName.Em)) <= SkillRules.StatBonus(GetTemp(StatName.Pr)) ? StatName.Em : StatName.Pr;
        if (es && ch) return SkillRules.StatBonus(GetTemp(StatName.Em)) <= SkillRules.StatBonus(GetTemp(StatName.In)) ? StatName.Em : StatName.In;
        if (ch) return StatName.In;
        if (es) return StatName.Em;
        if (me) return StatName.Pr;
        return StatName.Co;
    }

    StatName ResolveStatForBonus(string abbr) => abbr == "R*" ? GetRealmStat() : StatFromName(abbr);

    RenderFragment StepTalents => __builder =>
    {
        var racialTraits = _char!.Race is not null ? RaceRules.GetTraits(_char.Race) : [];
        var catalog      = _talentCategory == "All"
            ? TalentRules.All
            : TalentRules.All.Where(t => t.Category == _talentCategory).ToList();
        var selectedDef  = TalentRules.ByName.GetValueOrDefault(_talentName);
        int previewCost  = selectedDef is not null ? selectedDef.TotalCost(_talentTier) : 0;

        <h4>Step 5: Talents &amp; Flaws</h4>

        <!-- DP budget summary -->
        <div class="alert alert-secondary py-2 small mb-3">
            <strong>DP Budget:</strong> @_dpBudget total |
            Skills: @_dpSpent |
            Talents: @_talentDpSpent |
            <strong>Remaining: @_dpRemaining</strong>
        </div>

        <!-- Racial free traits -->
        @if (racialTraits.Any())
        {
            <div class="mb-3">
                <strong class="small">Racial Free Traits</strong>
                <div class="mt-1 d-flex flex-wrap gap-2">
                    @foreach (var rt in racialTraits)
                    {
                        <span class="badge @(rt.IsFlaw ? "bg-danger" : "bg-secondary")">@rt.Label</span>
                    }
                </div>
            </div>
        }
        else if (_char!.Race is null)
        {
            <p class="text-muted small">Select a race on Step 1 to see racial free traits.</p>
        }

        <!-- Purchased talents list -->
        @if (_char!.Talents.Any())
        {
            <h6 class="mt-3">Purchased Talents &amp; Flaws</h6>
            <ul class="list-unstyled small">
                @foreach (var t in _char.Talents.ToList())
                {
                    var def = TalentRules.ByName.GetValueOrDefault(t.TalentName);
                    int cost = TalentRules.TierCost(t.TalentName, t.Tier);
                    bool isPrior = _isLevelUp && _baselineTalentIds.Contains(t.Id);
                    <li class="d-flex align-items-center gap-2 mb-1 p-2 border rounded @(def?.IsFlaw == true ? "border-danger bg-dark" : "border-secondary bg-dark")">
                        <span class="@(def?.IsFlaw == true ? "text-danger" : isPrior ? "text-muted" : "text-light")">
                            <strong>@t.TalentName@(t.Tier > 1 ? $" {new[]{"","I","II","III","IV","V"}[Math.Min(t.Tier,5)]}" : "")@(t.Restriction is not null ? $" ({t.Restriction})" : "")</strong>
                            @if (def is not null) { <span class="text-muted"> — @def.Effect</span> }
                        </span>
                        @if (isPrior)
                        {
                            <span class="ms-auto badge bg-secondary">Permanent</span>
                        }
                        else
                        {
                            <span class="ms-auto badge @(cost < 0 ? "bg-danger" : "bg-primary")">@(cost > 0 ? $"+{cost}" : cost.ToString()) DP</span>
                            <button class="btn btn-sm btn-outline-danger py-0 px-1" @onclick="() => RemoveTalent(t)">×</button>
                        }
                    </li>
                }
            </ul>
        }

        <!-- Add talent form -->
        <div class="card mt-3">
            <div class="card-header py-1 fw-bold">Add Talent or Flaw</div>
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-2">
                        <label class="form-label form-label-sm mb-0">Category</label>
                        <select class="form-select form-select-sm"
                                @onchange="e => { _talentCategory = e.Value?.ToString() ?? string.Empty; _talentName = string.Empty; _talentTier = 1; }">
                            <option value="All">All</option>
                            @foreach (var cat in TalentRules.Categories)
                            { <option value="@cat" selected="@(_talentCategory == cat)">@cat</option> }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label form-label-sm mb-0">Talent / Flaw</label>
                        <select class="form-select form-select-sm"
                                @onchange="e => { _talentName = e.Value?.ToString() ?? string.Empty; _talentTier = 1; _talentRestriction = string.Empty; }">
                            <option value="">— select —</option>
                            @foreach (var td in catalog)
                            {
                                <option value="@td.Name" selected="@(_talentName == td.Name)">
                                    @(td.IsFlaw ? "⚠ " : "")@td.Name@(td.MaxTier != 1 ? " (tiered)" : "")
                                </option>
                            }
                        </select>
                    </div>
                    @if (selectedDef is not null && selectedDef.MaxTier != 1)
                    {
                        int maxTier = selectedDef.MaxTier == 0 ? 10 : selectedDef.MaxTier;
                        <div class="col-md-1">
                            <label class="form-label form-label-sm mb-0">Tier</label>
                            <select class="form-select form-select-sm"
                                    @onchange="e => _talentTier = int.TryParse(e.Value?.ToString(), out int v) ? v : 1">
                                @for (int i = 1; i <= maxTier; i++)
                                {
                                    var tier = i;
                                    <option value="@tier" selected="@(_talentTier == tier)">
                                        @(new[]{"","I","II","III","IV","V","VI","VII","VIII","IX","X"}[tier])
                                    </option>
                                }
                            </select>
                        </div>
                    }
                    @if (selectedDef?.NeedsSpec == true)
                    {
                        <div class="col-md-3">
                            <label class="form-label form-label-sm mb-0">Specialization</label>
                            <input class="form-control form-control-sm" placeholder="e.g. Fire, Tracking"
                                   value="@_talentRestriction"
                                   @oninput="e => _talentRestriction = e.Value?.ToString() ?? string.Empty" />
                        </div>
                    }
                    @if (selectedDef is not null)
                    {
                        <div class="col-auto">
                            <label class="form-label form-label-sm mb-0 d-block">
                                Cost: <strong class="@(previewCost < 0 ? "text-danger" : "text-success")">@previewCost DP</strong>
                            </label>
                            <button class="btn btn-sm @(selectedDef.IsFlaw ? "btn-outline-danger" : "btn-success")"
                                    disabled="@(!CanAddTalent(selectedDef, previewCost))"
                                    @onclick="AddTalent">
                                @(selectedDef.IsFlaw ? "Take Flaw" : "Add Talent")
                            </button>
                        </div>
                        @if (selectedDef is not null)
                        {
                            <div class="col-12 small text-muted">@selectedDef.Effect</div>
                        }
                    }
                </div>
            </div>
        </div>
    };

    bool CanAddTalent(TalentRules.TalentDef def, int cost)
    {
        if (string.IsNullOrWhiteSpace(_talentName)) return false;
        if (def.NeedsSpec && string.IsNullOrWhiteSpace(_talentRestriction)) return false;
        // Flaws always allowed; talents need DP
        if (!def.IsFlaw && _dpRemaining < cost) return false;
        return true;
    }

    void AddTalent()
    {
        if (string.IsNullOrWhiteSpace(_talentName) || _char is null) return;
        var def = TalentRules.ByName.GetValueOrDefault(_talentName);
        if (def is null) return;
        var entry = new CharacterTalent
        {
            CharacterId = _char.Id,
            TalentName  = _talentName,
            Tier        = def.MaxTier == 1 ? 1 : _talentTier,
            Restriction = def.NeedsSpec && !string.IsNullOrWhiteSpace(_talentRestriction)
                          ? _talentRestriction.Trim() : null,
        };
        _char.Talents.Add(entry);
        Db.CharacterTalents.Add(entry);
        _talentName = "";
        _talentTier = 1;
        _talentRestriction = "";
    }

    void RemoveTalent(CharacterTalent t)
    {
        _char!.Talents.Remove(t);
        Db.CharacterTalents.Remove(t);
    }

    RenderFragment StepEquipment => __builder =>
    {
        var armor   = ArmorRules.ByAT.GetValueOrDefault(_char!.ArmorType, ArmorRules.All[0]);
        var helm    = ArmorRules.Helmet(_char.HelmetGrade);
        var vamb    = ArmorRules.Vambrace(_char.VambracesGrade);
        var greave  = ArmorRules.Greave(_char.GreavesGrade);
        var shield  = ArmorRules.Shield(_char.ShieldType);

        int totalManPen = _char.ArmorFullSuit
            ? armor.FullManPen
            : armor.TorsoManPen + greave.ManPen;
        int armorWeight = _char.ArmorFullSuit
            ? armor.FullWeight + shield.Weight
            : armor.TorsoWeight + helm.Weight + vamb.Weight + greave.Weight + shield.Weight;
        int percPen    = helm.ManPen;
        int missilePen = vamb.ManPen;
        int itemCount  = _equipQty.Values.Sum();

        <h4>Step 5: Equipment</h4>

        <!-- ── ARMOR ──────────────────────────────────────────────────────── -->
        <h6 class="text-secondary mt-2 mb-2">Armor</h6>

        <div class="card mb-3">
            <div class="card-header py-1 fw-bold">Torso Armor</div>
            <div class="card-body py-2">
                <div class="row g-3">
                    <div class="col-md-5">
                        <label class="form-label">Armor Type</label>
                        <select class="form-select" @onchange="e => { _char!.ArmorType = int.TryParse(e.Value?.ToString(), out int v) ? v : 1; }">
                            @foreach (var a in ArmorRules.All)
                            {
                                <option value="@a.AT" selected="@(_char!.ArmorType == a.AT)">AT @a.AT – @a.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4 d-flex align-items-end">
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="checkbox" id="fullSuit"
                                   checked="@_char!.ArmorFullSuit"
                                   @onchange="e => _char!.ArmorFullSuit = (bool)(e.Value ?? false)" />
                            <label class="form-check-label" for="fullSuit">
                                Full Suit <span class="text-muted small">(incl. head, arms, legs)</span>
                            </label>
                        </div>
                    </div>
                </div>
                @if (_char!.ArmorType > 1)
                {
                    <div class="mt-2 small text-muted">
                        @if (_char.ArmorFullSuit)
                        {
                            <span>Full suit — ManPen: @armor.FullManPen | Weight: @armor.FullWeight lb | Enc: @($"{armor.FullEncPct * 100:F0}")% body wt</span>
                        }
                        else
                        {
                            <span>Torso only — ManPen: @armor.TorsoManPen | Weight: @armor.TorsoWeight lb | Enc: @($"{armor.TorsoEncPct * 100:F0}")% body wt</span>
                        }
                    </div>
                }
            </div>
        </div>

        @if (!_char!.ArmorFullSuit)
        {
            <div class="card mb-3">
                <div class="card-header py-1 fw-bold">Piecemeal Pieces</div>
                <div class="card-body py-2">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Helmet</label>
                            <select class="form-select" @onchange="e => _char!.HelmetGrade = e.Value?.ToString()">
                                @foreach (var p in ArmorRules.Helmets)
                                {
                                    <option value="@p.Grade" selected="@((_char!.HelmetGrade ?? "None") == p.Grade)">
                                        @p.Grade@(p.AT > 1 ? $" (AT {p.AT})" : "") @(p.ManPen != 0 ? $"  {p.ManPen} perc." : "")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Vambraces <span class="text-muted small">(ranged pen.)</span></label>
                            <select class="form-select" @onchange="e => _char!.VambracesGrade = e.Value?.ToString()">
                                @foreach (var p in ArmorRules.Vambraces)
                                {
                                    <option value="@p.Grade" selected="@((_char!.VambracesGrade ?? "None") == p.Grade)">
                                        @p.Grade@(p.AT > 1 ? $" (AT {p.AT})" : "") @(p.ManPen != 0 ? $"  {p.ManPen} ranged" : "")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Greaves</label>
                            <select class="form-select" @onchange="e => _char!.GreavesGrade = e.Value?.ToString()">
                                @foreach (var p in ArmorRules.Greaves)
                                {
                                    <option value="@p.Grade" selected="@((_char!.GreavesGrade ?? "None") == p.Grade)">
                                        @p.Grade@(p.AT > 1 ? $" (AT {p.AT})" : "") @(p.ManPen != 0 ? $"  {p.ManPen}" : "")
                                    </option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="card mb-3">
            <div class="card-header py-1 fw-bold">Shield</div>
            <div class="card-body py-2">
                <div class="col-md-4">
                    <label class="form-label">Shield Type <span class="text-muted small">(DB from Shield skill)</span></label>
                    <select class="form-select" @onchange="e => _char!.ShieldType = e.Value?.ToString()">
                        @foreach (var s in ArmorRules.Shields)
                        {
                            <option value="@s.Type" selected="@((_char!.ShieldType ?? "None") == s.Type)">
                                @s.Type@(s.AT > 1 ? $" (AT {s.AT}, {s.Weight} lb)" : "")
                            </option>
                        }
                    </select>
                </div>
            </div>
        </div>

        <div class="alert alert-secondary py-2 small mb-4">
            <strong>Armor summary</strong> —
            Maneuver Penalty: <strong>@totalManPen</strong> |
            Perception Penalty: <strong>@percPen</strong> |
            Ranged Penalty: <strong>@missilePen</strong> |
            Armor Weight: <strong>@armorWeight lb</strong>
        </div>

        <!-- ── WEAPONS ────────────────────────────────────────────────────── -->
        <h6 class="text-secondary mt-2 mb-2">Weapons</h6>
        <div class="card mb-3">
            <div class="card-body p-0">
                <table class="table table-sm table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Weapon</th>
                            <th class="text-center" style="width:60px">2H</th>
                            <th class="text-end" style="width:80px">Cost</th>
                            <th class="text-end" style="width:80px">Wt (lb)</th>
                            <th class="text-center" style="width:110px">Qty</th>
                            <th class="text-muted small">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cat in EquipmentRules.WeaponCategories)
                        {
                            <tr class="table-secondary">
                                <td colspan="6" class="fw-semibold py-1 ps-2 small">@cat</td>
                            </tr>
                            @foreach (var w in EquipmentRules.Weapons.Where(x => x.Category == cat))
                            {
                                var wQty = GetEquipQty(w.Name);
                                var wName = w.Name;
                                <tr class="@(wQty > 0 ? "table-primary" : "")">
                                    <td>@w.Name</td>
                                    <td class="text-center">@(w.TwoHanded ? "2H" : "")</td>
                                    <td class="text-end">@w.Cost</td>
                                    <td class="text-end">@w.WeightLbs</td>
                                    <td class="text-center">
                                        <button class="btn qp-btn-minus" @onclick="() => AdjEquipQty(wName, -1)" disabled="@(wQty == 0)">−</button>
                                        <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@wQty</span>
                                        <button class="btn qp-btn-plus" @onclick="() => AdjEquipQty(wName, 1)">+</button>
                                    </td>
                                    <td class="text-muted small">@w.Notes</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ── GENERAL EQUIPMENT ──────────────────────────────────────────── -->
        <h6 class="text-secondary mt-2 mb-2">General Equipment</h6>
        <div class="card mb-3">
            <div class="card-body p-0">
                <table class="table table-sm table-bordered table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Item</th>
                            <th class="text-end" style="width:80px">Cost</th>
                            <th class="text-end" style="width:80px">Wt (lb)</th>
                            <th class="text-center" style="width:110px">Qty</th>
                            <th class="text-muted small">Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in EquipmentRules.General)
                        {
                            var gQty = GetEquipQty(item.Name);
                            var gName = item.Name;
                            <tr class="@(gQty > 0 ? "table-primary" : "")">
                                <td>@item.Name</td>
                                <td class="text-end">@item.Cost</td>
                                <td class="text-end">@(item.WeightLbs > 0 ? item.WeightLbs.ToString("G") : "—")</td>
                                <td class="text-center">
                                    <button class="btn qp-btn-minus" @onclick="() => AdjEquipQty(gName, -1)" disabled="@(gQty == 0)">−</button>
                                    <span class="mx-1" style="min-width:1.2em;display:inline-block;text-align:center">@gQty</span>
                                    <button class="btn qp-btn-plus" @onclick="() => AdjEquipQty(gName, 1)">+</button>
                                </td>
                                <td class="text-muted small">@item.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="alert alert-info py-2 small">
            <strong>Carry weight</strong> —
            Armor: <strong>@armorWeight lb</strong> |
            Items: <strong>@TotalEquipWeight lb</strong> |
            Total: <strong>@(armorWeight + TotalEquipWeight) lb</strong>
            @if (itemCount > 0)
            {
                <span class="ms-2 text-muted">(@itemCount item type@(itemCount != 1 ? "s" : "") selected)</span>
            }
        </div>
    };


}
