<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["RolemasterCharacterCreation.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet />
</head>

<body class="@BodyClass">
    <RolemasterCharacterCreation.Components.Routes />
    <RulesAssistant />
    <ReconnectModal />
    <script src="@Assets["lib/bootstrap/dist/js/bootstrap.bundle.min.js"]"></script>
    <script src="app.js"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>

@code {
    [Inject] private IHttpContextAccessor Http { get; set; } = default!;

    // Tags the page for phone players so the site nav can be hidden (they are chat-only).
    private string? BodyClass
    {
        get
        {
            var user = Http.HttpContext?.User;
            var isPhonePlayer = user?.Identity?.IsAuthenticated == true
                && user.IsInRole(RolemasterCharacterCreation.Identity.Roles.Player)
                && !user.IsInRole(RolemasterCharacterCreation.Identity.Roles.Gamemaster)
                && RolemasterCharacterCreation.Services.MobileDetection.IsPhone(
                    Http.HttpContext?.Request.Headers.UserAgent.ToString());
            return isPhonePlayer ? "phone-chat-only" : null;
        }
    }
}
