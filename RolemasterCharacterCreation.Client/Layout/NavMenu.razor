</style>

@code {
    private record RealmMenu(string Realm, string[] Categories);

    // Categories grouped by realm, matching the seeded Spell Law data.
    private static readonly RealmMenu[] SpellMenu =
    [
        new("Channeling", ["Open Channeling", "Closed Channeling", "Cleric Base", "Druid Base",
                           "Paladin Base", "Ranger Base", "Evil Channeling"]),
        new("Essence", ["Open Essence", "Closed Essence", "Bard Base", "Dabbler Base",
                        "Illusionist Base", "Magician Base", "Evil Essence"]),
        new("Mentalism", ["Open Mentalism", "Closed Mentalism", "Lay Healer Base", "Magent Base",
                          "Mentalist Base", "Monk Base", "Evil Mentalism"]),
        new("Hybrid", ["Healer Base", "Mystic Base", "Sorcerer Base"]),
    ];
}
